---
// Pied de page commun — IDENTIQUE à celui de la page d'accueil (index.astro).
// Les ancres pointent vers la page d'accueil (/#...).
const year = new Date().getFullYear();
---

<footer class="border-t border-border-soft bg-white">
  <div class="mx-auto max-w-7xl px-5 py-14 sm:px-8">
    <div class="grid gap-10 md:grid-cols-4">
      <div class="md:col-span-1">
        <a href="/" class="flex items-center">
          <img src="/brand/logo.svg" alt="Netair" class="h-8 w-auto" />
        </a>
        <p class="mt-4 max-w-xs text-sm text-secondary">L'air propre, notre engagement.</p>
      </div>
      <div>
        <h4 class="text-xs font-normal uppercase tracking-wider text-primary">Gammes</h4>
        <ul class="mt-4 space-y-2.5 text-sm text-secondary">
          <li><a href="/gammes/prefiltres" class="link-underline hover:text-accent">Préfiltres</a></li>
          <li><a href="/gammes/poches-souples" class="link-underline hover:text-accent">Filtres à poches</a></li>
          <li><a href="/gammes/hepa" class="link-underline hover:text-accent">HEPA / absolus</a></li>
          <li><a href="/gammes" class="link-underline hover:text-accent">Tout le catalogue</a></li>
        </ul>
      </div>
      <div>
        <h4 class="text-xs font-normal uppercase tracking-wider text-primary">Entreprise</h4>
        <ul class="mt-4 space-y-2.5 text-sm text-secondary">
          <li><a href="/#performance" class="link-underline hover:text-accent">Performance</a></li>
          <li><a href="/#secteurs" class="link-underline hover:text-accent">Secteurs</a></li>
          <li><a href="/a-propos" class="link-underline hover:text-accent">À propos</a></li>
          <li><a href="/contact" class="link-underline hover:text-accent">Contact</a></li>
        </ul>
      </div>
      <div>
        <h4 class="text-xs font-normal uppercase tracking-wider text-primary">Contact</h4>
        <ul class="mt-4 space-y-2.5 text-sm text-secondary">
          <li class="flex items-center gap-2"><svg class="h-4 w-4 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-10 6L2 7"/></svg> contact@netair.fr</li>
          <li><a href="/mentions-legales" class="link-underline hover:text-accent">Mentions légales</a></li>
          <li><a href="/confidentialite" class="link-underline hover:text-accent">Confidentialité</a></li>
        </ul>
      </div>
    </div>
    <div class="mt-12 flex flex-col items-center justify-between gap-4 border-t border-border-soft pt-6 text-sm text-secondary sm:flex-row">
      <p>© {year} Netair. Tous droits réservés.</p>
      <p class="text-secondary/70">Filtration EN ISO 16890 · EN 779 · EN 1822</p>
    </div>
  </div>
</footer>
