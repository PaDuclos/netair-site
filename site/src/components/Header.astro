---
// En-tête : logo sur fond blanc + lame turquoise verticale + navigation.
const links = [
  { href: '/gammes', label: 'Gammes' },
  { href: '/a-propos', label: 'À propos' },
  { href: '/contact', label: 'Contact' },
];
const path = Astro.url.pathname;
---

<header class="sticky top-0 z-30 bg-blanc/85 backdrop-blur-md border-b border-soft">
  <div class="relative mx-auto max-w-[1140px] px-7">
    <!-- Lame turquoise verticale (remplace l'ancien bandeau bleu) -->
    <span class="absolute left-0 top-2 bottom-2 w-[3px] bg-turquoise rounded-full" aria-hidden="true"></span>

    <div class="flex items-center justify-between py-3.5">
      <a href="/" class="flex items-center" aria-label="Netair — accueil">
        <img src="/brand/logo.svg" alt="Netair" class="h-8 w-auto" />
      </a>

      <nav class="hidden md:flex items-center gap-8" aria-label="Navigation principale">
        {links.map((l) => (
          <a
            href={l.href}
            class:list={[
              'text-sm font-medium transition-colors hover:text-marine',
              path.startsWith(l.href) ? 'text-marine' : 'text-muted',
            ]}
          >
            {l.label}
          </a>
        ))}
      </nav>

      <a
        href="/contact"
        class="inline-flex items-center gap-2 rounded-xl px-4 py-2.5 text-sm font-semibold text-blanc shadow-[0_10px_24px_-10px_rgba(8,151,165,0.55)] transition-transform hover:-translate-y-0.5"
        style="background-image: linear-gradient(135deg, var(--color-bleu), var(--color-turquoise));"
      >
        Demander un devis →
      </a>
    </div>
  </div>
</header>
