---
// En-tête commun — IDENTIQUE à celui de la page d'accueil (index.astro).
// Les liens d'ancre pointent vers la page d'accueil (/#...) pour fonctionner
// depuis n'importe quelle page intérieure.
---

<header id="nav" class="fixed inset-x-0 top-0 z-40 transition-all duration-300">
  <div class="mx-auto max-w-7xl px-5 sm:px-8">
    <div id="nav-inner" class="mt-3 flex h-16 items-center justify-between rounded-2xl glass px-4 shadow-soft transition-all duration-300">
      <a href="/" class="flex items-center cursor-pointer" aria-label="Netair, accueil">
        <img src="/brand/logo.svg" alt="Netair" class="h-8 w-auto" />
      </a>

      <nav class="hidden items-center gap-8 md:flex" aria-label="Navigation principale">
        <a href="/#solutions" class="link-underline text-sm font-normal text-secondary hover:text-primary">Solutions</a>
        <a href="/gammes" class="link-underline text-sm font-normal text-secondary hover:text-primary">Catalogue</a>
        <a href="/#performance" class="link-underline text-sm font-normal text-secondary hover:text-primary">Performance</a>
        <a href="/#secteurs" class="link-underline text-sm font-normal text-secondary hover:text-primary">Secteurs</a>
        <a href="/#process" class="link-underline text-sm font-normal text-secondary hover:text-primary">Notre approche</a>
      </nav>

      <div class="flex items-center gap-4 sm:gap-5">
        <!-- Demander un devis : lien secondaire + compteur -->
        <a href="/devis" class="hidden items-center gap-1.5 text-sm font-normal text-secondary transition-colors hover:text-primary sm:inline-flex">
          Demander un devis
          <span id="devis-badge" class="hidden min-w-[18px] rounded-full bg-mist px-1 text-center text-[11px] font-medium leading-[18px] text-marine">0</span>
        </a>
        <!-- Se connecter : entrée espace client (page /compte « bientôt ») -->
        <a href="/compte" class="inline-flex items-center gap-1.5 text-sm font-normal text-secondary transition-colors hover:text-primary cursor-pointer" aria-label="Se connecter">
          <svg class="h-[18px] w-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          <span class="hidden sm:inline">Se connecter</span>
        </a>
        <!-- Panier (style boutique) : chariot + compteur marine posé dessus + « Panier » -->
        <a href="/panier" id="cart-link" class="inline-flex items-center gap-1.5 text-marine transition-transform duration-200 hover:-translate-y-0.5 cursor-pointer" aria-label="Voir le panier">
          <span class="relative inline-flex h-6 w-7 items-center">
            <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
            <span id="cart-badge" class="absolute left-[9px] -top-0.5 hidden text-[13px] font-medium leading-none text-marine">0</span>
          </span>
          <span class="text-[15px] font-medium">Panier</span>
        </a>
      </div>
    </div>
  </div>
</header>
<!-- Cale pour compenser l'en-tête fixe -->
<div class="h-[88px]" aria-hidden="true"></div>

<script>
  import { cartCount, onCartChange } from '../lib/cart';
  import { devisCount, onDevisChange } from '../lib/devis';

  const cartBadge = document.getElementById('cart-badge');
  const devisBadge = document.getElementById('devis-badge');
  const maj = (el, n) => { if (el) { el.textContent = String(n); el.classList.toggle('hidden', n === 0); } };

  const majPanier = () => maj(cartBadge, cartCount());
  const majDevis = () => maj(devisBadge, devisCount());
  majPanier(); onCartChange(majPanier);
  majDevis(); onDevisChange(majDevis);
</script>
