---
// En-tête commun — IDENTIQUE à celui de la page d'accueil (index.astro).
// Les liens d'ancre pointent vers la page d'accueil (/#...) pour fonctionner
// depuis n'importe quelle page intérieure.
---

<header id="nav" class="fixed inset-x-0 top-0 z-40 transition-all duration-300">
  <div class="mx-auto max-w-7xl px-5 sm:px-8">
    <div id="nav-inner" class="mt-3 flex h-16 items-center justify-between rounded-2xl glass px-4 shadow-soft transition-all duration-300">
      <a href="/" class="flex items-center cursor-pointer" aria-label="Netair, accueil">
        <img src="/brand/logo.svg" alt="Netair" class="h-8 w-auto" />
      </a>

      <nav class="hidden items-center gap-8 md:flex" aria-label="Navigation principale">
        <a href="/#solutions" class="link-underline text-sm font-normal text-secondary hover:text-primary">Solutions</a>
        <a href="/gammes" class="link-underline text-sm font-normal text-secondary hover:text-primary">Catalogue</a>
        <a href="/#performance" class="link-underline text-sm font-normal text-secondary hover:text-primary">Performance</a>
        <a href="/#secteurs" class="link-underline text-sm font-normal text-secondary hover:text-primary">Secteurs</a>
        <a href="/#process" class="link-underline text-sm font-normal text-secondary hover:text-primary">Notre approche</a>
      </nav>

      <div class="flex items-center gap-2 sm:gap-5">
        <!-- Menu mobile (hamburger) : ouvre les liens de navigation sous md -->
        <button id="menu-toggle" type="button" class="inline-flex items-center rounded-xl p-2 text-secondary transition-colors hover:text-primary md:hidden" aria-label="Ouvrir le menu" aria-expanded="false" aria-controls="mobile-menu">
          <svg id="menu-open-icon" class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
          <svg id="menu-close-icon" class="hidden h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
        <!-- Demander un devis : lien secondaire + compteur -->
        <a href="/devis" class="hidden items-center gap-1.5 text-sm font-normal text-secondary transition-colors hover:text-primary sm:inline-flex">
          Demander un devis
          <span id="devis-badge" class="hidden min-w-[18px] rounded-full bg-mist px-1 text-center text-[11px] font-medium leading-[18px] text-marine">0</span>
        </a>
        <!-- Se connecter : icône seule (entrée espace client, page /compte « bientôt ») -->
        <a href="/compte" class="inline-flex items-center rounded-xl p-2 text-secondary transition-colors hover:text-primary cursor-pointer" aria-label="Se connecter">
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        </a>
        <!-- Panier : bouton plein (l'action mise en avant) -->
        <a href="/panier" id="cart-link" class="inline-flex items-center gap-2 rounded-xl brand-gradient px-4 py-2.5 text-sm font-normal text-white shadow-soft transition-all duration-200 hover:shadow-lift cursor-pointer" aria-label="Voir le panier">
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
          Panier
          <span id="cart-badge" class="hidden rounded-full bg-white/25 px-1.5 text-[11px] font-medium leading-[18px]">0</span>
        </a>
      </div>
    </div>

    <!-- Panneau du menu mobile (masqué par défaut, ouvert par le hamburger) -->
    <div id="mobile-menu" class="hidden md:hidden">
      <nav class="mt-2 flex flex-col rounded-2xl glass px-3 py-3 shadow-soft" aria-label="Menu mobile">
        <a href="/gammes" class="rounded-lg px-3 py-2.5 text-sm font-normal text-secondary transition-colors hover:bg-mist hover:text-primary">Catalogue</a>
        <a href="/#solutions" class="rounded-lg px-3 py-2.5 text-sm font-normal text-secondary transition-colors hover:bg-mist hover:text-primary">Solutions</a>
        <a href="/#performance" class="rounded-lg px-3 py-2.5 text-sm font-normal text-secondary transition-colors hover:bg-mist hover:text-primary">Performance</a>
        <a href="/#secteurs" class="rounded-lg px-3 py-2.5 text-sm font-normal text-secondary transition-colors hover:bg-mist hover:text-primary">Secteurs</a>
        <a href="/#process" class="rounded-lg px-3 py-2.5 text-sm font-normal text-secondary transition-colors hover:bg-mist hover:text-primary">Notre approche</a>
        <a href="/devis" class="mt-1 rounded-lg border-t border-soft px-3 pb-2.5 pt-3 text-sm font-normal text-secondary transition-colors hover:bg-mist hover:text-primary">Demander un devis</a>
      </nav>
    </div>
  </div>
</header>
<!-- Cale pour compenser l'en-tête fixe -->
<div class="h-[88px]" aria-hidden="true"></div>

<script>
  import { cartCount, onCartChange } from '../lib/cart';
  import { devisCount, onDevisChange } from '../lib/devis';

  const cartBadge = document.getElementById('cart-badge');
  const devisBadge = document.getElementById('devis-badge');
  const maj = (el, n) => { if (el) { el.textContent = String(n); el.classList.toggle('hidden', n === 0); } };

  const majPanier = () => maj(cartBadge, cartCount());
  const majDevis = () => maj(devisBadge, devisCount());
  majPanier(); onCartChange(majPanier);
  majDevis(); onDevisChange(majDevis);

  // Menu mobile (hamburger) : ouverture/fermeture + bascule de l'icône.
  const menuToggle = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  const openIcon = document.getElementById('menu-open-icon');
  const closeIcon = document.getElementById('menu-close-icon');
  if (menuToggle && mobileMenu) {
    const setOpen = (open) => {
      mobileMenu.classList.toggle('hidden', !open);
      openIcon?.classList.toggle('hidden', open);
      closeIcon?.classList.toggle('hidden', !open);
      menuToggle.setAttribute('aria-expanded', String(open));
    };
    menuToggle.addEventListener('click', () => setOpen(mobileMenu.classList.contains('hidden')));
    mobileMenu.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => setOpen(false)));
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') setOpen(false); });
    document.addEventListener('click', (e) => {
      if (!mobileMenu.classList.contains('hidden') && !mobileMenu.contains(e.target) && !menuToggle.contains(e.target)) setOpen(false);
    });
  }
</script>
