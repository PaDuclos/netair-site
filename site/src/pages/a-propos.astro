---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';

const blocs = [
  {
    titre: "Raison d'être",
    texte:
      "Netair conçoit et fabrique des filtres pour centrales de traitement d'air. Notre ligne de conduite est simple : ne mettre en avant que ce qui est mesuré, et accompagner chaque client en termes techniques.",
  },
  {
    titre: 'Notre modèle',
    texte:
      "Fabrication et assemblage en interne, complétés par une sous-traitance maîtrisée. Cette organisation nous permet de tenir à la fois le catalogue standard et le sur-mesure, sans rallonger les délais.",
  },
];

const engagements = [
  {
    titre: 'Performance documentée',
    texte: "Classes, pertes de charge et durées de service issues de nos essais.",
  },
  {
    titre: 'Accompagnement',
    texte: 'Un interlocuteur technique, pas un standard commercial.',
  },
  {
    titre: 'Démarche responsable',
    texte:
      'Nos filtres rechargeables (gamme NETPAK S LUMEN) conservent la carcasse et ne remplacent que les cassettes filtrantes, pour réduire les déchets.',
  },
];
---

<BaseLayout
  title="À propos — Netair, fabricant de filtres pour CTA"
  description="Netair, fabricant français de filtres pour centrales de traitement d'air : fabrication interne et sous-traitance maîtrisée, performance documentée, démarche responsable."
>
  <section class="mx-auto max-w-[1140px] px-7 pt-10 pb-4">
    <Breadcrumb items={[{ href: '/', label: 'Accueil' }, { label: 'À propos' }]} />
    <h1 class="display mt-5 text-4xl sm:text-5xl font-bold text-marine max-w-3xl">
      Un fabricant français de filtres pour le traitement d'air
    </h1>
  </section>

  <section class="mx-auto max-w-[1140px] px-7 py-8 grid gap-10 md:grid-cols-2">
    {blocs.map((b) => (
      <div class="relative pl-5">
        <span class="absolute left-0 top-1 bottom-1 w-[3px] rounded-full bg-turquoise"></span>
        <h2 class="display text-2xl text-marine">{b.titre}</h2>
        <p class="mt-3 text-lg leading-relaxed text-muted">{b.texte}</p>
      </div>
    ))}
  </section>

  <section class="mx-auto max-w-[1140px] px-7 py-8">
    <h2 class="display text-3xl font-bold text-marine">Nos engagements</h2>
    <div class="mt-8 grid gap-4 md:grid-cols-3">
      {engagements.map((e, i) => (
        <div class="rounded-2xl border border-soft bg-blanc p-6">
          <div class="display text-sm text-muted">0{i + 1}</div>
          <h3 class="display mt-1 text-xl text-marine">{e.titre}</h3>
          <p class="mt-2 text-sm text-muted">{e.texte}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="mx-auto max-w-[1140px] px-7 py-12">
    <div class="rounded-3xl border border-soft bg-mist px-8 py-14 text-center">
      <p class="display text-2xl sm:text-3xl font-bold text-marine">L'air propre, notre engagement.</p>
      <a
        href="/contact"
        class="mt-7 inline-flex items-center gap-2 rounded-xl px-6 py-3 text-sm font-semibold text-blanc shadow-[0_10px_24px_-10px_rgba(8,151,165,0.55)] transition-transform hover:-translate-y-0.5"
        style="background-image: linear-gradient(135deg, var(--color-bleu), var(--color-turquoise));"
      >
        Demander un devis →
      </a>
    </div>
  </section>
</BaseLayout>
