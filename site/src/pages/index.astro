          <h3 class="font-display mt-4 font-normal text-primary">Agroalimentaire</h3>
          <p class="mt-1.5 text-sm text-secondary">Maîtrise de la contamination, conformité hygiène et sécurité produit.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ░░░ Process ░░░ -->
  <section id="process" class="bg-white py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-5 sm:px-8">
      <div class="max-w-2xl">
        <span class="reveal text-sm font-normal uppercase tracking-wider text-accent">Notre approche</span>
        <h2 class="reveal font-display mt-3 text-3xl font-normal tracking-tight text-primary sm:text-4xl">Du devis à la livraison, un accompagnement continu</h2>
      </div>

      <ol class="mt-14 grid gap-8 md:grid-cols-4">
        <li class="reveal relative">
          <span class="font-mono text-sm font-normal text-accent">01</span>
          <div class="mt-3 h-px w-full bg-gradient-to-r from-accent to-transparent"></div>
