---
// Page d'accueil — reproduction fidèle du design de l'ancien index.html
// (mêmes polices, encadrés, sections, effets). Contenu rendu VRAI :
// normes au lieu de faux clients, citation du fondateur au lieu d'un faux
// témoignage, vrais chiffres au lieu des chiffres inventés.
// Page autonome (Tailwind CDN + Google Fonts) pour un rendu identique à l'original.
//
// Section « Nos solutions » + liens « Gammes » du pied de page : GÉNÉRÉS depuis
// FAMILLES (même source unique que le catalogue /gammes) → plus de lien cassé ni
// de divergence quand une famille change. Seuls l'icône et l'accroche restent
// décoratifs (par slug, avec repli) ; liens/titres/descriptions viennent de FAMILLES.
import { FAMILLES } from '../lib/familles';

const icones: Record<string, string> = {
  prefiltres: '<rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M3 15h18M9 3v18M15 3v18"/>',
  'compacts-miniplis': '<path d="M4 4h16v16H4z"/><path d="M4 9h16M9 9v11"/>',
  'poches-souples-rigides': '<path d="M3 7v10M7 4v16M11 7v10M15 4v16M19 7v10"/>',
  hepa: '<path d="M12 2 4 6v6c0 5 3.5 8 8 10 4.5-2 8-5 8-10V6z"/><path d="m9 12 2 2 4-4"/>',
  'charbon-actif': '<path d="M12 3a9 9 0 1 0 9 9"/><path d="M12 3v9l6 3"/>',
  combines: '<rect x="3" y="3" width="13" height="13" rx="2"/><rect x="8" y="8" width="13" height="13" rx="2"/>',
};
const accroches: Record<string, string> = {
  prefiltres: 'Ventilation générale',
  'compacts-miniplis': 'Filtration fine',
  'poches-souples-rigides': 'Grande capacité',
  hepa: 'Très haute efficacité',
  'charbon-actif': 'Gaz & odeurs',
  combines: 'Particules + gaz',
};
---

<!doctype html>
<html lang="fr" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Netair — Filtres pour centrales de traitement d'air (CTA)</title>
  <meta name="description" content="Netair, fabricant français de filtres pour la ventilation générale (CTA) : préfiltres, compacts miniplis, poches souples et rigides, filtres absolus HEPA, charbons actifs. Double classification EN ISO 16890 et EN 779. Devis sur mesure." />

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <script src="https://cdn.tailwindcss.com" is:inline></script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

  <script is:inline>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            primary:   '#0F3261',
            secondary: '#4A5E7A',
            accent:    '#0897A5',
            'accent-bright': '#0070C8',
            background:'#F8FAFC',
            foreground:'#0F3261',
            muted:     '#ECF1F4',
            'border-soft': '#E2E8F0',
          },
          fontFamily: {
            sans: ['DM Sans', 'system-ui', 'sans-serif'],
            display: ['Space Grotesk', 'DM Sans', 'sans-serif'],
            mono: ['JetBrains Mono', 'monospace'],
          },
          boxShadow: {
            soft: '0 1px 2px rgba(15,50,97,.05), 0 8px 24px -8px rgba(15,50,97,.12)',
            lift: '0 24px 60px -24px rgba(8,151,165,.42)',
          },
        },
      },
    };
  </script>

  <style is:global>
    :root { color-scheme: light; }
    body { font-family: 'DM Sans', system-ui, sans-serif; }
    .font-display { font-family: 'Space Grotesk', 'DM Sans', sans-serif; }
    .brand-gradient { background-image: linear-gradient(135deg, #0070C8 0%, #0897A5 100%); }

    .mesh {
      background:
        radial-gradient(60% 60% at 12% 18%, rgba(8,151,165,.20), transparent 60%),
        radial-gradient(50% 50% at 88% 8%, rgba(0,112,200,.22), transparent 60%),
        radial-gradient(60% 60% at 78% 82%, rgba(15,50,97,.16), transparent 60%);
    }
    .blob {
      position: absolute; border-radius: 9999px; filter: blur(60px); opacity: .5;
      animation: drift 18s ease-in-out infinite;
    }
    @keyframes drift {
      0%,100% { transform: translate3d(0,0,0) scale(1); }
      50%     { transform: translate3d(24px,-30px,0) scale(1.08); }
    }

    .glass {
      background: rgba(255,255,255,.65);
      backdrop-filter: blur(14px); -webkit-backdrop-filter: blur(14px);
      border: 1px solid rgba(255,255,255,.6);
    }
    .glass-dark {
      background: rgba(15,50,97,.55);
      backdrop-filter: blur(14px); -webkit-backdrop-filter: blur(14px);
      border: 1px solid rgba(255,255,255,.08);
    }

    .reveal { opacity: 0; transform: translateY(24px); transition: opacity .7s cubic-bezier(.22,1,.36,1), transform .7s cubic-bezier(.22,1,.36,1); }
    .reveal.in { opacity: 1; transform: none; }

    .link-underline { background-image: linear-gradient(currentColor,currentColor); background-size: 0% 1.5px; background-position: 0 100%; background-repeat: no-repeat; transition: background-size .3s ease; }
    .link-underline:hover { background-size: 100% 1.5px; }

    @media (prefers-reduced-motion: reduce) {
      .blob { animation: none; }
      .reveal { opacity: 1; transform: none; transition: none; }
      html { scroll-behavior: auto; }
    }
  </style>
</head>

<body class="bg-background text-foreground antialiased selection:bg-accent/20">

  <a href="#hero" class="sr-only focus:not-sr-only focus:absolute focus:z-50 focus:top-3 focus:left-3 focus:rounded-lg focus:bg-primary focus:px-4 focus:py-2 focus:text-white">Aller au contenu</a>

  <!-- ░░░ Header ░░░ -->
  <header id="nav" class="fixed inset-x-0 top-0 z-40 transition-all duration-300">
    <div class="mx-auto max-w-7xl px-5 sm:px-8">
      <div class="mt-3 flex h-16 items-center justify-between rounded-2xl glass px-4 shadow-soft transition-all duration-300">
        <a href="#hero" class="flex items-center cursor-pointer" aria-label="Netair, accueil">
          <img src="/brand/logo.svg" alt="Netair" class="h-8 w-auto" />
        </a>

        <nav class="hidden items-center gap-8 md:flex" aria-label="Navigation principale">
          <a href="#solutions" class="link-underline text-sm font-normal text-secondary hover:text-primary">Solutions</a>
          <a href="/gammes" class="link-underline text-sm font-normal text-secondary hover:text-primary">Catalogue</a>
          <a href="#performance" class="link-underline text-sm font-normal text-secondary hover:text-primary">Performance</a>
          <a href="#secteurs" class="link-underline text-sm font-normal text-secondary hover:text-primary">Secteurs</a>
          <a href="#process" class="link-underline text-sm font-normal text-secondary hover:text-primary">Notre approche</a>
        </nav>

        <div class="flex items-center gap-3">
          <a href="/contact" class="hidden text-sm font-normal text-secondary hover:text-primary sm:block link-underline">Nous contacter</a>
          <a href="/contact" class="group inline-flex items-center gap-1.5 rounded-xl brand-gradient px-4 py-2.5 text-sm font-normal text-white shadow-soft transition-all duration-200 hover:shadow-lift cursor-pointer">
            Demander un devis
            <svg class="h-4 w-4 transition-transform duration-200 group-hover:translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </div>
  </header>

  <!-- ░░░ Hero ░░░ -->
  <section id="hero" class="relative overflow-hidden mesh pt-36 pb-24 sm:pt-44 sm:pb-32">
    <div class="blob -left-20 top-10 h-72 w-72 bg-accent-bright/40" aria-hidden="true"></div>
    <div class="blob right-0 top-40 h-80 w-80 bg-accent/40" style="animation-delay:-6s" aria-hidden="true"></div>

    <div class="relative mx-auto max-w-7xl px-5 sm:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <span class="reveal inline-flex items-center gap-2 rounded-full border border-border-soft bg-white/70 px-4 py-1.5 text-xs font-normal uppercase tracking-wider text-accent shadow-soft">
          <span class="h-1.5 w-1.5 rounded-full bg-accent animate-pulse"></span>
          La filtration nouvelle génération
        </span>

        <h1 class="reveal font-display mt-6 text-4xl font-normal leading-[1.08] tracking-tight text-primary sm:text-6xl" style="transition-delay:.05s">
          Respirez un air<br class="hidden sm:block" /> <span class="bg-gradient-to-r from-accent to-accent-bright bg-clip-text text-transparent">vraiment maîtrisé</span>.
        </h1>

        <p class="reveal mx-auto mt-6 max-w-xl text-lg leading-relaxed text-secondary" style="transition-delay:.1s">
          Netair conçoit des solutions de filtration d'air pour la ventilation générale de l'industrie et du tertiaire — performance certifiée, suivi connecté et délais courts. La filtration, en plus simple.
        </p>

        <div class="reveal mt-9 flex flex-col items-center justify-center gap-3 sm:flex-row" style="transition-delay:.15s">
          <a href="/contact" class="group inline-flex w-full items-center justify-center gap-2 rounded-xl brand-gradient px-6 py-3.5 text-sm font-normal text-white shadow-lift transition-all duration-200 hover:brightness-110 sm:w-auto cursor-pointer">
            Obtenir une étude gratuite
            <svg class="h-4 w-4 transition-transform duration-200 group-hover:translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <a href="#solutions" class="inline-flex w-full items-center justify-center gap-2 rounded-xl border border-border-soft bg-white/70 px-6 py-3.5 text-sm font-normal text-primary shadow-soft transition-all duration-200 hover:bg-white sm:w-auto cursor-pointer">
            Découvrir nos solutions
          </a>
        </div>
      </div>

      <!-- KPI strip (chiffres VRAIS) -->
      <div class="reveal mx-auto mt-16 grid max-w-4xl grid-cols-2 gap-px overflow-hidden rounded-2xl glass shadow-soft sm:grid-cols-4" style="transition-delay:.2s">
        <div class="bg-white/40 px-6 py-7 text-center">
          <div class="font-display text-3xl font-normal text-primary" data-count="6">0</div>
          <p class="mt-1 text-xs font-normal uppercase tracking-wider text-secondary">familles de filtres</p>
        </div>
        <div class="bg-white/40 px-6 py-7 text-center">
          <div class="font-display text-3xl font-normal text-primary" data-count="14">0</div>
          <p class="mt-1 text-xs font-normal uppercase tracking-wider text-secondary">références au catalogue</p>
        </div>
        <div class="bg-white/40 px-6 py-7 text-center">
          <div class="font-display text-xl font-normal text-primary leading-tight">EN ISO 16890<br />+ EN 779</div>
          <p class="mt-1 text-xs font-normal uppercase tracking-wider text-secondary">double classification</p>
        </div>
        <div class="bg-white/40 px-6 py-7 text-center">
          <div class="font-display text-2xl font-normal text-primary">Sur mesure</div>
          <p class="mt-1 text-xs font-normal uppercase tracking-wider text-secondary">devis au cas par cas</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ░░░ Bande normes (au lieu de faux clients) ░░░ -->
  <section aria-label="Conformité" class="border-y border-border-soft bg-white">
    <div class="mx-auto max-w-7xl px-5 py-10 sm:px-8">
      <p class="text-center text-xs font-normal uppercase tracking-[0.2em] text-secondary/70">Conformité &amp; références normatives</p>
      <div class="mt-7 flex flex-wrap items-center justify-center gap-x-10 gap-y-4 opacity-80">
        {['EN ISO 16890','EN 779','EN 1822','Classement au feu M1','Fabrication française'].map((n) => (
          <span class="inline-flex items-center gap-2 font-display text-base font-normal text-primary/70">
            <svg class="h-5 w-5 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
            {n}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- ░░░ Solutions ░░░ -->
  <section id="solutions" class="py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-5 sm:px-8">
      <div class="max-w-2xl">
        <span class="reveal text-sm font-normal uppercase tracking-wider text-accent">Nos solutions</span>
        <h2 class="reveal font-display mt-3 text-3xl font-normal tracking-tight text-primary sm:text-4xl">Une gamme complète, du préfiltre au très haute efficacité</h2>
        <p class="reveal mt-4 text-lg text-secondary">Chaque étage de filtration répond à un besoin précis. Netair dimensionne la solution selon votre débit, votre charge particulaire et vos contraintes énergétiques.</p>
      </div>

      <div class="mt-14 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {FAMILLES.map((f, i) => (
          <a href={`/gammes/${f.slug}`} class="reveal group relative flex flex-col rounded-2xl border border-border-soft bg-white p-7 shadow-soft transition-all duration-300 hover:-translate-y-1.5 hover:shadow-lift hover:border-accent/30" style={`transition-delay:${(i % 3) * 0.05}s`}>
            <span class="grid h-12 w-12 place-items-center rounded-xl bg-accent/10 text-accent transition-colors duration-300 group-hover:brand-gradient group-hover:text-white">
              <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" set:html={icones[f.slug] ?? icones.prefiltres}></svg>
            </span>
            <h3 class="font-display mt-5 text-lg font-normal text-primary">{f.titre}</h3>
            <p class="mt-2 flex-1 text-sm leading-relaxed text-secondary">{f.desc}</p>
            <span class="mt-5 font-mono text-xs uppercase tracking-wider text-accent">{accroches[f.slug] ?? f.tag}</span>
          </a>
        ))}

        <div class="reveal group relative flex flex-col rounded-2xl border border-dashed border-border-soft bg-white p-7 shadow-soft" style="transition-delay:.1s">
          <span class="grid h-12 w-12 place-items-center rounded-xl bg-accent/10 text-accent">
            <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="m7 14 4-4 3 3 5-6"/></svg>
          </span>
          <h3 class="font-display mt-5 text-lg font-normal text-primary">Suivi connecté &amp; maintenance</h3>
          <p class="mt-2 flex-1 text-sm leading-relaxed text-secondary">Capteurs de perte de charge, alertes de remplacement et tableau de bord en ligne pour piloter vos filtres en temps réel.</p>
          <span class="mt-5 inline-block w-fit rounded-full bg-accent-bright/10 px-3 py-1 font-mono text-xs uppercase tracking-wider text-accent-bright">À venir</span>
        </div>
      </div>

      <div class="reveal mt-12 text-center">
        <a href="/gammes" class="group inline-flex items-center justify-center gap-2 rounded-xl border border-border-soft bg-white px-6 py-3.5 text-sm font-normal text-primary shadow-soft transition-all duration-200 hover:border-accent/40 hover:shadow-lift cursor-pointer">
          Voir le catalogue complet
          <svg class="h-4 w-4 transition-transform duration-200 group-hover:translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ░░░ Performance ░░░ -->
  <section id="performance" class="relative overflow-hidden bg-primary py-24 text-white sm:py-32">
    <div class="blob right-10 -top-10 h-72 w-72 bg-accent/50" aria-hidden="true"></div>
    <div class="relative mx-auto max-w-7xl px-5 sm:px-8">
      <div class="grid items-center gap-14 lg:grid-cols-2">
        <div>
          <span class="reveal text-sm font-normal uppercase tracking-wider text-accent-bright">Performance &amp; conformité</span>
          <h2 class="reveal font-display mt-3 text-3xl font-normal tracking-tight sm:text-4xl">La norme EN ISO 16890, appliquée sans compromis</h2>
          <p class="reveal mt-4 text-lg leading-relaxed text-white/70">Netair classe chaque filtre selon son efficacité réelle sur les particules ePM1, ePM2,5 et ePM10 — celles qui pénètrent le plus profondément dans les voies respiratoires. Pas d'approximation : les valeurs de chaque produit figurent sur sa fiche technique.</p>

          <dl class="reveal mt-10 grid gap-6 sm:grid-cols-2">
            <div class="rounded-2xl glass-dark p-5">
              <dt class="flex items-center gap-2 text-sm font-normal text-white">
                <svg class="h-5 w-5 text-accent-bright" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="m9 11 3 3 8-8"/><path d="M21 12a9 9 0 1 1-6.2-8.6"/></svg>
                Efficacité énergétique
              </dt>
              <dd class="mt-2 text-sm text-white/60">Faible perte de charge = moins de consommation ventilateur sur toute la durée de vie.</dd>
            </div>
            <div class="rounded-2xl glass-dark p-5">
              <dt class="flex items-center gap-2 text-sm font-normal text-white">
                <svg class="h-5 w-5 text-accent-bright" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v4M12 18v4M2 12h4M18 12h4"/><circle cx="12" cy="12" r="4"/></svg>
                Traçabilité
              </dt>
              <dd class="mt-2 text-sm text-white/60">Chaque référence documentée : classes, perte de charge et durée de service sur sa fiche.</dd>
            </div>
            <div class="rounded-2xl glass-dark p-5">
              <dt class="flex items-center gap-2 text-sm font-normal text-white">
                <svg class="h-5 w-5 text-accent-bright" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3h18v18H3z"/><path d="m8 12 3 3 5-6"/></svg>
                Conformité EN 1822
              </dt>
              <dd class="mt-2 text-sm text-white/60">Filtres HEPA testés selon EN 1822.</dd>
            </div>
            <div class="rounded-2xl glass-dark p-5">
              <dt class="flex items-center gap-2 text-sm font-normal text-white">
                <svg class="h-5 w-5 text-accent-bright" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20 7 9 18l-5-5"/></svg>
                Double classification
              </dt>
              <dd class="mt-2 text-sm text-white/60">EN ISO 16890 (primaire) et EN 779, sur chaque référence.</dd>
            </div>
          </dl>
        </div>

        <div class="reveal rounded-3xl glass-dark p-2 shadow-lift">
          <div class="rounded-[1.25rem] bg-white/5 p-6">
            <p class="font-display text-sm font-normal uppercase tracking-wider text-accent-bright">Échelle de finesse de filtration</p>
            <div class="mt-5 space-y-3 font-mono text-sm">
              <div class="flex items-center justify-between border-b border-white/10 pb-3">
                <span class="text-white/80">ISO Coarse <span class="text-white/40">(G3/G4)</span></span>
                <div class="flex items-center gap-3"><div class="h-2 w-28 overflow-hidden rounded-full bg-white/10"><div class="h-full w-[28%] rounded-full bg-accent-bright"></div></div></div>
              </div>
              <div class="flex items-center justify-between border-b border-white/10 pb-3">
                <span class="text-white/80">ePM10 <span class="text-white/40">(M5/M6)</span></span>
                <div class="flex items-center gap-3"><div class="h-2 w-28 overflow-hidden rounded-full bg-white/10"><div class="h-full w-[48%] rounded-full bg-accent-bright"></div></div></div>
              </div>
              <div class="flex items-center justify-between border-b border-white/10 pb-3">
                <span class="text-white/80">ePM1 <span class="text-white/40">(F7/F9)</span></span>
                <div class="flex items-center gap-3"><div class="h-2 w-28 overflow-hidden rounded-full bg-white/10"><div class="h-full w-[82%] rounded-full bg-accent-bright"></div></div></div>
              </div>
              <div class="flex items-center justify-between">
                <span class="text-white/80">HEPA H14 <span class="text-white/40">(EN 1822)</span></span>
                <div class="flex items-center gap-3"><div class="h-2 w-28 overflow-hidden rounded-full bg-white/10"><div class="h-full w-[99%] rounded-full brand-gradient"></div></div></div>
              </div>
            </div>
            <p class="mt-5 text-xs text-white/40">Échelle indicative du plus grossier au plus fin. L'efficacité exacte de chaque produit est précisée sur sa fiche technique.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ░░░ Secteurs ░░░ -->
  <section id="secteurs" class="py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-5 sm:px-8">
      <div class="mx-auto max-w-2xl text-center">
        <span class="reveal text-sm font-normal uppercase tracking-wider text-accent">Secteurs</span>
        <h2 class="reveal font-display mt-3 text-3xl font-normal tracking-tight text-primary sm:text-4xl">Un air adapté à chaque environnement</h2>
        <p class="reveal mt-4 text-lg text-secondary">Des ateliers de production aux blocs opératoires, Netair adapte l'étage de filtration à vos enjeux sanitaires, réglementaires et énergétiques.</p>
      </div>

      <div class="mt-14 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        <div class="reveal group rounded-2xl border border-border-soft bg-white p-6 shadow-soft transition-all duration-300 hover:border-accent/40 hover:shadow-lift cursor-default">
          <svg class="h-8 w-8 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M2 20h20"/><path d="M4 20V8l6-3v15"/><path d="M10 20V5l8 4v11"/><path d="M14 12h.01M14 16h.01"/></svg>
          <h3 class="font-display mt-4 font-normal text-primary">Industrie &amp; process</h3>
          <p class="mt-1.5 text-sm text-secondary">Protection des lignes, captation à la source, traitement d'air procédé.</p>
        </div>
        <div class="reveal group rounded-2xl border border-border-soft bg-white p-6 shadow-soft transition-all duration-300 hover:border-accent/40 hover:shadow-lift cursor-default" style="transition-delay:.05s">
          <svg class="h-8 w-8 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21V7l9-4 9 4v14"/><path d="M9 21v-6h6v6"/><path d="M9 10h.01M15 10h.01"/></svg>
          <h3 class="font-display mt-4 font-normal text-primary">Santé &amp; laboratoires</h3>
          <p class="mt-1.5 text-sm text-secondary">Salles propres, blocs, hottes — filtration absolue et hygiène contrôlée.</p>
        </div>
        <div class="reveal group rounded-2xl border border-border-soft bg-white p-6 shadow-soft transition-all duration-300 hover:border-accent/40 hover:shadow-lift cursor-default" style="transition-delay:.1s">
          <svg class="h-8 w-8 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 22V4a2 2 0 0 1 2-2h8l6 6v14"/><path d="M14 2v6h6"/><path d="M8 13h8M8 17h8"/></svg>
