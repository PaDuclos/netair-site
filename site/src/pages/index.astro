---
import BaseLayout from '../layouts/BaseLayout.astro';
import { FAMILLES, getProduits, getProduitsByFamille } from '../lib/familles';

const produits = await getProduits();
const nbProduits = produits.length;

// KPI — chiffres VRAIS uniquement (familles, références, normes, sur-mesure).
const stats = [
  { count: FAMILLES.length, suffix: '', label: 'familles de filtres' },
  { count: nbProduits, suffix: '', label: 'références au catalogue' },
  { text: 'EN ISO 16890 + EN 779', label: 'double classification' },
  { text: 'Sur mesure', label: 'devis au cas par cas' },
];

// Bande de confiance — normes réelles (remplace les faux logos clients).
const normes = ['EN ISO 16890', 'EN 779', 'EN 1822', 'Classement au feu M1', 'Fabrication française'];

// Icônes par famille (SVG inline, trait fin cohérent).
const ICONS: Record<string, string> = {
  prefiltres: '<rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M3 15h18M9 3v18M15 3v18"/>',
  'filtres-plans': '<rect x="3" y="5" width="18" height="14" rx="2"/><path d="M3 10h18M3 14h18"/>',
  'poches-souples': '<path d="M3 7v10M7 4v16M11 7v10M15 4v16M19 7v10"/>',
  compacts: '<rect x="3" y="4" width="18" height="16" rx="2"/><path d="M7 4v16M11 4v16M15 4v16"/>',
  hepa: '<path d="M12 2 4 6v6c0 5 3.5 8 8 10 4.5-2 8-5 8-10V6z"/><path d="m9 12 2 2 4-4"/>',
  'charbon-actif': '<path d="M12 3a9 9 0 1 0 9 9"/><path d="M12 3v9l6 3"/>',
  combines: '<circle cx="9" cy="12" r="6"/><circle cx="15" cy="12" r="6"/>',
};

// Comptage par famille (libellé adapté si une famille n'a pas encore de référence).
const famillesData = await Promise.all(
  FAMILLES.map(async (f) => ({ ...f, count: (await getProduitsByFamille(f.slug)).length })),
);

// Échelle de finesse (qualitative, conforme aux normes — aucun % inventé).
const echelle = [
  { label: 'ISO Coarse', sub: 'préfiltration (G3 · G4)', w: 28 },
  { label: 'ePM10', sub: 'particules ≤ 10 µm (M5 · M6)', w: 48 },
  { label: 'ePM2,5', sub: 'particules ≤ 2,5 µm (F7)', w: 66 },
  { label: 'ePM1', sub: 'particules ≤ 1 µm (F8 · F9)', w: 82 },
  { label: 'HEPA H14', sub: '≥ 99,995 % (EN 1822)', w: 99 },
];

const process = [
  { t: 'Besoin & devis', d: "Vous nous transmettez vos références ou vos cotes ; nous étudions chaque demande." },
  { t: 'Dimensionnement', d: 'Choix de la classe de filtration et calcul du gain énergétique sur la durée de vie.' },
  { t: 'Fabrication', d: 'Production interne et sous-traitance maîtrisée, en standard comme en sur-mesure.' },
  { t: 'Livraison', d: 'Expédition par transporteur, partout en France.' },
];

const mosaic = [
  { src: '/produits/netply-v6-photo.jpg', nom: 'NETPLY', type: 'Filtre plissé' },
  { src: '/produits/netpak-s-cilia-photo.jpg', nom: 'NETPAK S CILIA', type: 'Compact' },
  { src: '/produits/netcel-v-nival-photo.jpg', nom: 'NETCEL V NIVAL', type: 'HEPA / T.H.E' },
];
const arrow =
  '<svg class="h-4 w-4 transition-transform duration-200 group-hover:translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>';
---

<BaseLayout
  title="Netair — Filtres pour centrales de traitement d'air (CTA)"
  description="Fabricant français de filtres pour la ventilation générale : préfiltres, poches, compacts F9, HEPA H14. Double classification EN ISO 16890 et EN 779. Devis sur mesure."
>
  <!-- ░░ HERO ░░ -->
  <section class="relative overflow-hidden mesh pt-12 pb-12">
    <div class="blob -left-20 top-10 h-72 w-72 bg-bleu/40" aria-hidden="true"></div>
    <div class="blob right-0 top-40 h-80 w-80 bg-turquoise/40" style="animation-delay:-6s" aria-hidden="true"></div>

    <div class="relative mx-auto max-w-[1140px] px-7 grid items-center gap-12 lg:grid-cols-2">
      <div>
        <span class="eyebrow inline-flex items-center gap-2 rounded-full border border-soft bg-blanc/70 px-3.5 py-1.5 text-xs text-turquoise shadow-soft">
          <span class="h-1.5 w-1.5 rounded-full bg-turquoise"></span>
          Fabricant de filtres pour CTA
        </span>
        <h1 class="mt-5 text-5xl sm:text-6xl font-bold leading-[1.03] text-marine">
          Des filtres pour le traitement d'air,<br /><span class="brand-text">conçus pour durer.</span>
        </h1>
        <p class="mt-5 max-w-xl text-lg text-muted">
          Du préfiltre métallique au compact F9 : une gamme complète pour la ventilation
          générale, en double classification EN ISO 16890 et EN 779. Chaque référence,
          sa fiche technique et son calculateur énergétique.
        </p>
        <div class="mt-8 flex flex-wrap gap-3.5">
          <a href="/contact" class="brand-gradient group inline-flex items-center gap-2 rounded-xl px-5 py-3 text-sm font-semibold text-blanc shadow-lift transition-all hover:brightness-110">
            Demander un devis <Fragment set:html={arrow} />
          </a>
          <a href="/gammes" class="inline-flex items-center gap-2 rounded-xl border border-soft bg-blanc/70 px-5 py-3 text-sm font-semibold text-marine shadow-soft transition-colors hover:bg-blanc hover:border-turquoise">
            Voir les gammes
          </a>
        </div>
      </div>

      <!-- Mosaïque de 3 filtres -->
      <div class="grid grid-cols-2 gap-4">
        <figure class="row-span-2 rounded-2xl glass p-4 shadow-lift">
          <img src={mosaic[0].src} alt={`${mosaic[0].nom} — ${mosaic[0].type}`} class="h-full w-full rounded-lg object-cover" loading="eager" width="520" height="640" />
          <figcaption class="mt-3 text-sm"><span class="font-semibold text-marine">{mosaic[0].nom}</span> · <span class="text-muted">{mosaic[0].type}</span></figcaption>
        </figure>
        {mosaic.slice(1).map((m) => (
          <figure class="rounded-2xl glass p-3 shadow-soft">
            <img src={m.src} alt={`${m.nom} — ${m.type}`} class="aspect-square w-full rounded-lg object-cover" loading="lazy" width="320" height="320" />
            <figcaption class="mt-2 text-xs"><span class="font-semibold text-marine">{m.nom}</span><br /><span class="text-muted">{m.type}</span></figcaption>
          </figure>
        ))}
      </div>
    </div>

    <!-- KPI strip -->
    <div class="relative mx-auto mt-14 max-w-[1140px] px-7">
      <div class="grid grid-cols-2 gap-px overflow-hidden rounded-2xl glass shadow-soft sm:grid-cols-4">
        {stats.map((s) => (
          <div class="bg-blanc/40 px-6 py-7 text-center">
            {s.text ? (
              <div class="display text-xl font-bold text-marine">{s.text}</div>
            ) : (
              <div class="display text-3xl font-bold text-marine">{s.count}{s.suffix}</div>
            )}
            <p class="mt-1 text-xs font-medium uppercase tracking-wider text-muted">{s.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ░░ Bande normes (confiance réelle) ░░ -->
  <section aria-label="Conformité" class="border-y border-soft bg-blanc">
    <div class="mx-auto max-w-[1140px] px-7 py-10">
      <p class="text-center eyebrow text-xs text-muted">Conformité & références normatives</p>
      <div class="mt-6 flex flex-wrap items-center justify-center gap-x-8 gap-y-3">
        {normes.map((n) => (
          <span class="inline-flex items-center gap-2 text-sm font-semibold text-marine/70">
            <svg class="h-4 w-4 text-turquoise" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
            {n}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- ░░ NOTRE MÉTIER ░░ -->
  <section class="mx-auto max-w-[1140px] px-7 py-16 reveal">
    <span class="eyebrow text-xs text-turquoise">Notre métier</span>
    <p class="mt-3 max-w-3xl text-2xl leading-snug text-marine">
      Netair fabrique et assemble des filtres pour centrales de traitement d'air.
      Production interne et sous-traitance maîtrisée nous permettent de couvrir le
      catalogue standard comme le sur-mesure. Livraison par transporteur, partout en France.
    </p>
  </section>

  <!-- ░░ GAMMES ░░ -->
  <section class="mx-auto max-w-[1140px] px-7 pb-8 reveal">
    <div class="flex items-end justify-between gap-6">
      <div>
        <span class="eyebrow text-sm text-turquoise">Nos gammes</span>
        <h2 class="display mt-2 text-3xl font-bold text-marine">Une gamme complète, du préfiltre au très haute efficacité</h2>
        <p class="mt-3 max-w-2xl text-muted">
          Sept familles, du préfiltre à la filtration absolue. Chaque produit est documenté :
          classes de filtration, perte de charge et durée de service sur sa fiche technique.
        </p>
      </div>
      <a href="/gammes" class="hidden shrink-0 sm:inline text-sm font-semibold text-turquoise hover:text-marine">Tout voir →</a>
    </div>

    <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {famillesData.map((f) => (
        <a href={`/gammes/${f.slug}`} class="group relative flex flex-col rounded-2xl border border-soft bg-blanc p-7 shadow-soft transition-all duration-300 hover:-translate-y-1.5 hover:shadow-lift hover:border-turquoise/30">
          <span class="grid h-12 w-12 place-items-center rounded-xl bg-turquoise/10 text-turquoise transition-colors duration-300 group-hover:brand-gradient group-hover:text-blanc">
            <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" set:html={ICONS[f.slug]} />
          </span>
          <h3 class="display mt-5 text-lg text-marine">{f.titre}</h3>
          <p class="mt-2 flex-1 text-sm leading-relaxed text-muted">{f.desc}</p>
          <span class="mt-5 text-xs font-semibold uppercase tracking-wider text-turquoise">
            {f.count > 0 ? `${f.count} ${f.count > 1 ? 'références' : 'référence'} →` : 'Bientôt disponible'}
          </span>
        </a>
      ))}
    </div>
  </section>

  <!-- ░░ PERFORMANCE (sombre) ░░ -->
  <section class="relative overflow-hidden bg-marine py-24 text-blanc mt-12">
    <div class="blob right-10 -top-10 h-72 w-72 bg-turquoise/50" aria-hidden="true"></div>
    <div class="relative mx-auto max-w-[1140px] px-7 grid items-center gap-14 lg:grid-cols-2">
      <div>
        <span class="eyebrow text-sm text-bleu">Performance & conformité</span>
        <h2 class="display mt-3 text-3xl font-bold sm:text-4xl">La norme EN ISO 16890, appliquée sans compromis</h2>
        <p class="mt-4 text-lg leading-relaxed text-blanc/70">
          Nos filtres sont classés selon leur efficacité réelle sur les particules ePM1,
          ePM2,5 et ePM10 — celles qui pénètrent le plus profondément dans les voies
          respiratoires. Pas d'approximation : les valeurs de chaque produit figurent sur
          sa fiche technique.
        </p>

        <dl class="mt-10 grid gap-4 sm:grid-cols-2">
          {[
            ['Performance documentée', 'Classes et pertes de charge issues de nos essais.'],
            ['Double classification', 'EN ISO 16890 (primaire) et EN 779, sur chaque référence.'],
            ['Conformité EN 1822', 'Filtres HEPA testés selon EN 1822.'],
            ['Calculateur énergétique', "L'écart d'énergie chiffré pour votre débit."],
          ].map(([t, d]) => (
            <div class="rounded-2xl glass-dark p-5">
              <dt class="flex items-center gap-2 text-sm font-semibold text-blanc">
                <svg class="h-5 w-5 text-bleu" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 11 3 3 8-8"/><path d="M21 12a9 9 0 1 1-6.2-8.6"/></svg>
                {t}
              </dt>
              <dd class="mt-2 text-sm text-blanc/60">{d}</dd>
            </div>
          ))}
        </dl>
      </div>

      <div class="rounded-3xl glass-dark p-2 shadow-lift">
        <div class="rounded-[1.25rem] bg-white/5 p-6">
          <p class="eyebrow text-sm text-bleu">Échelle de finesse de filtration</p>
          <div class="mt-5 space-y-4">
            {echelle.map((e) => (
              <div>
                <div class="flex items-center justify-between text-sm">
                  <span class="font-semibold text-blanc">{e.label}</span>
                  <span class="text-blanc/50">{e.sub}</span>
                </div>
                <div class="mt-1.5 h-2 w-full overflow-hidden rounded-full bg-white/10">
                  <div class="h-full rounded-full brand-gradient" style={`width:${e.w}%`}></div>
                </div>
              </div>
            ))}
          </div>
          <p class="mt-5 text-xs text-blanc/40">Échelle indicative du plus grossier au plus fin. L'efficacité exacte est précisée sur la fiche de chaque produit.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ░░ PROCESS ░░ -->
  <section class="mx-auto max-w-[1140px] px-7 py-20 reveal">
    <span class="eyebrow text-sm text-turquoise">Notre approche</span>
    <h2 class="display mt-3 text-3xl font-bold text-marine">Du devis à la livraison, un accompagnement technique</h2>
    <ol class="mt-12 grid gap-8 md:grid-cols-4">
      {process.map((p, i) => (
        <li class="relative">
          <span class="display text-sm font-semibold text-turquoise">0{i + 1}</span>
          <div class="mt-3 h-px w-full bg-gradient-to-r from-turquoise to-transparent"></div>
          <h3 class="display mt-4 text-lg text-marine">{p.t}</h3>
          <p class="mt-2 text-sm text-muted">{p.d}</p>
        </li>
      ))}
    </ol>

    <!-- Service à venir -->
    <div class="mt-12 flex flex-col items-start gap-3 rounded-2xl border border-dashed border-soft bg-mist/60 p-6 sm:flex-row sm:items-center sm:justify-between">
      <div class="flex items-center gap-3">
        <span class="grid h-10 w-10 place-items-center rounded-xl bg-turquoise/10 text-turquoise">
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a9 9 0 1 0 9 9"/><path d="M12 3v9l6 3"/></svg>
        </span>
        <div>
          <p class="font-semibold text-marine">Suivi connecté de vos filtres</p>
          <p class="text-sm text-muted">Alertes de remplacement et pilotage de la perte de charge.</p>
        </div>
      </div>
      <span class="rounded-full bg-bleu/10 px-3 py-1 text-xs font-semibold text-bleu">À venir</span>
    </div>
  </section>

  <!-- ░░ CTA final (sombre) ░░ -->
  <section class="mx-auto max-w-[1140px] px-7 pb-20">
    <div class="relative overflow-hidden rounded-[2rem] bg-marine px-8 py-16 text-center shadow-lift sm:px-16">
      <div class="blob -right-10 -top-10 h-72 w-72 bg-turquoise/60" aria-hidden="true"></div>
      <div class="blob left-0 bottom-0 h-64 w-64 bg-bleu/40" style="animation-delay:-9s" aria-hidden="true"></div>
      <div class="relative">
        <h2 class="display text-3xl font-bold text-blanc sm:text-4xl">Un besoin précis ? Un devis précis.</h2>
        <p class="mx-auto mt-3 max-w-xl text-blanc/70">
          Indiquez vos références ou vos dimensions ; nous revenons avec une proposition
          adaptée à votre installation.
        </p>
        <a href="/contact" class="brand-gradient group mt-8 inline-flex items-center gap-2 rounded-xl px-6 py-3.5 text-sm font-semibold text-blanc shadow-lift transition-all hover:brightness-110">
          Demander un devis <Fragment set:html={arrow} />
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
