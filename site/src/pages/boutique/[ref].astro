---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import {
  getProduits,
  familleBySlug,
  SLUG_FAMILLE,
  type Produit,
} from '../../lib/familles';
import { gammeDuProduit } from '../../lib/pricing/produits-gammes';
import { optionsDuCode } from '../../lib/pricing/options';

export async function getStaticPaths() {
  const produits = await getProduits();
  return produits.map((p) => ({ params: { ref: p.id }, props: { produit: p } }));
}

interface Props {
  produit: Produit;
}
const { produit } = Astro.props;
const d = produit.data;

const famille = familleBySlug(SLUG_FAMILLE[produit.id]?.[0] ?? '');
const img = d.photo ? `/produits/${d.photo}` : null;

// Lien vers la fiche technique générée (servie depuis /public/fiches-techniques/).
const ficheHref = `/fiches-techniques/${encodeURIComponent(`Fiche technique ${d.nom}.html`)}`;

const badges: string[] = d.badges_p1 ?? [];
const specs: string[][] = d.specs ?? [];
const points: string[] = d.points_cles ?? [];
const codeBase = d.nom.replace(/\s+/g, '');

// --- Pont vers le moteur de prix (Bloc B2) ---
// On relie le produit du site à sa gamme tarifaire. `mode` = "calcul" (prix instantané)
// ou "devis" (gamme hors calculateur → demande de devis seule). Produit non répertorié
// → on reste prudent : pas de prix public.
const gamme = gammeDuProduit(produit.id);
const modeProduit: 'calcul' | 'devis' = gamme?.mode ?? 'devis';
const codeGamme = gamme?.code ?? '';

// Menus adaptés : pour un produit calculable, on ne propose QUE les efficacités et
// épaisseurs réellement tarifées (lues dans les tables). Pour un produit sur devis,
// on garde un repli générique (la classe sert alors juste à préciser la demande, sans prix).
const REPLI_DEVIS = {
  classes: [
    { valeur: 'G4', libelle: 'Coarse 65 % (G4)' },
    { valeur: 'M5', libelle: 'ePM10 50 % (M5)' },
    { valeur: 'F7', libelle: 'ePM1 55 % (F7)' },
  ],
  epaisseurs: [48, 98] as number[],
};
const optsReelles = modeProduit === 'calcul' && codeGamme ? optionsDuCode(codeGamme) : null;
const menus = optsReelles && optsReelles.classes.length > 0 ? optsReelles : REPLI_DEVIS;
---

<BaseLayout
  title={`${d.nom} — ${d.soustitre ?? 'Filtre CTA'} | Netair`}
  description={(d.description ?? `${d.nom}, filtre pour centrale de traitement d'air.`).slice(0, 300)}
  ogImage={img ?? '/brand/logo.png'}
>
  <!-- Bandeau maquette -->
  <div class="bg-marine text-blanc">
    <div class="mx-auto max-w-[1140px] px-7 py-2 text-center text-xs">
      Aperçu boutique · prix catalogue HT réels mais <strong>indicatifs et non contractuels</strong> (avant mise en ligne)
    </div>
  </div>

  <section class="mx-auto max-w-[1140px] px-7 pt-10">
    <Breadcrumb
      items={[
        { href: '/', label: 'Accueil' },
        { href: '/gammes', label: 'Gammes' },
        ...(famille ? [{ href: `/gammes/${famille.slug}`, label: famille.titre }] : []),
        { label: d.nom },
      ]}
    />
  </section>

  <!-- En-tête produit -->
  <section class="mx-auto max-w-[1140px] px-7 py-8 grid items-start gap-10 lg:grid-cols-2">
    {img && (
      <div class="rounded-2xl border border-soft bg-white p-6">
        <img src={img} alt={d.photo_alt ?? `Filtre ${d.nom}`} class="mx-auto h-auto w-full max-w-md object-contain" width="520" height="400" />
      </div>
    )}
    <div>
      {famille && <span class="eyebrow text-xs text-turquoise">{famille.titre}</span>}
      <h1 class="display mt-2 text-4xl sm:text-5xl font-normal text-marine">{d.nom}</h1>
      {d.soustitre && <p class="mt-2 text-lg text-muted">{d.soustitre}</p>}

      {badges.length > 0 && (
        <div class="mt-5 flex flex-wrap gap-2">
          {badges.map((b) => (
            <span class="rounded-lg bg-bleu/8 px-3 py-1.5 text-xs font-normal text-bleu">{b}</span>
          ))}
        </div>
      )}

      {points.length > 0 && (
        <ul class="mt-6 grid gap-2 sm:grid-cols-2">
          {points.map((pt) => (
            <li class="flex items-start gap-2 text-sm text-marine">
              <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-turquoise"></span>
              {pt}
            </li>
          ))}
        </ul>
      )}

      <div class="mt-8 flex flex-wrap gap-3">
        <a
          href="#boutique"
          class="inline-flex items-center gap-2 rounded-xl px-5 py-3 text-sm font-normal text-blanc shadow-[0_10px_24px_-10px_rgba(8,151,165,0.55)] transition-transform hover:-translate-y-0.5"
          style="background-image: linear-gradient(135deg, var(--color-bleu), var(--color-turquoise));"
        >
          Configurer & commander →
        </a>
        <a
          href="#boutique"
          class="inline-flex items-center gap-2 rounded-xl border border-soft bg-blanc px-5 py-3 text-sm font-normal text-marine transition-colors hover:border-turquoise"
        >
          Demander un devis
        </a>
        <a
          href={ficheHref}
          class="inline-flex items-center gap-2 rounded-xl border border-soft bg-blanc px-5 py-3 text-sm font-normal text-marine transition-colors hover:border-turquoise"
        >
          Fiche technique
        </a>
      </div>
    </div>
  </section>

  <!-- Description -->
  {d.description && (
    <section class="mx-auto max-w-[1140px] px-7 py-6">
      <h2 class="eyebrow text-xs text-turquoise">Description</h2>
      <p class="mt-3 max-w-3xl text-lg leading-relaxed text-marine">{d.description}</p>
    </section>
  )}

  <!-- Caractéristiques -->
  {specs.length > 0 && (
    <section class="mx-auto max-w-[1140px] px-7 py-6">
      <h2 class="display text-2xl font-normal text-marine">Caractéristiques</h2>
      <div class="mt-5 overflow-hidden rounded-2xl border border-soft">
        <table class="w-full text-sm">
          <tbody>
            {specs.map((row, i) => (
              <tr class={i % 2 ? 'bg-mist' : 'bg-blanc'}>
                <th scope="row" class="w-1/3 px-5 py-3 text-left font-normal text-muted align-top">{row[0]}</th>
                <td class="px-5 py-3 text-marine">{row[1]}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="mt-3 text-xs text-muted">
        Valeurs issues de la fiche technique du produit. Perte de charge et classement énergétique détaillés sur la fiche.
      </p>
    </section>
  )}

  <!-- Configurateur + Panier + Demande de devis -->
  <section class="mx-auto max-w-[1140px] px-7 py-6 scroll-mt-24" id="boutique" data-nom={d.nom} data-code={codeBase} data-codegamme={codeGamme} data-mode={modeProduit}>
    <h2 class="display text-2xl font-normal text-marine">Configurer votre filtre</h2>
    <p class="mt-1 text-sm text-muted">Indiquez vos dimensions exactes : achetez au tarif catalogue, ou ajoutez à une demande de devis. Filtre fabriqué sur mesure.</p>

    <div class="mt-6 grid gap-7 lg:grid-cols-[1.3fr_1fr]">

      <!-- Configurateur -->
      <div class="rounded-2xl border border-soft bg-white p-5 shadow-soft">
        <div class="grid gap-x-5 gap-y-3.5 sm:grid-cols-2">
          <label class="block">
            <span class="eyebrow text-[11px] text-muted">Largeur (mm)</span>
            <input id="inL" type="number" value="592" min="100" max="2000" step="1"
              class="mt-1.5 w-full rounded-xl border border-soft bg-mist px-4 py-2 text-marine outline-none focus:border-turquoise" />
          </label>
          <label class="block">
            <span class="eyebrow text-[11px] text-muted">Hauteur (mm)</span>
            <input id="inH" type="number" value="592" min="100" max="2000" step="1"
              class="mt-1.5 w-full rounded-xl border border-soft bg-mist px-4 py-2 text-marine outline-none focus:border-turquoise" />
          </label>
          <label class="block">
            <span class="eyebrow text-[11px] text-muted">Épaisseur</span>
            <select id="inEp"
              class="mt-1.5 w-full rounded-xl border border-soft bg-mist px-4 py-2 text-marine outline-none focus:border-turquoise">
              {menus.epaisseurs.map((ep, i) => (
                <option value={ep} selected={i === 0}>{ep} mm</option>
              ))}
            </select>
          </label>
          <label class="block">
            <span class="eyebrow text-[11px] text-muted">Efficacité</span>
            <select id="inEff"
              class="mt-1.5 w-full rounded-xl border border-soft bg-mist px-4 py-2 text-marine outline-none focus:border-turquoise">
              {menus.classes.map((c, i) => (
                <option value={c.valeur} selected={i === 0}>{c.libelle}</option>
              ))}
            </select>
          </label>
          <label class="block">
            <span class="eyebrow text-[11px] text-muted">Cadre</span>
            <select id="inCadre"
              class="mt-1.5 w-full rounded-xl border border-soft bg-mist px-4 py-2 text-marine outline-none focus:border-turquoise">
              <option value="galva">Acier galvanisé</option>
              <option value="pp">Polypropylène</option>
            </select>
          </label>
          <label class="block">
            <span class="eyebrow text-[11px] text-muted">Quantité</span>
            <input id="inQ" type="number" value="6" min="1" max="100000" step="1"
              class="mt-1.5 w-full rounded-xl border border-soft bg-mist px-4 py-2 text-marine outline-none focus:border-turquoise" />
          </label>
          <div class="block">
            <span class="eyebrow text-[11px] text-muted">Référence générée</span>
            <div id="genRef" class="mt-1.5 w-full rounded-xl border border-dashed border-soft bg-mist px-4 py-2 font-mono text-sm text-marine"></div>
          </div>
        </div>

        <!-- Prix + actions -->
        <div class="mt-5 rounded-2xl bg-mist px-5 py-4">
          <div class="flex flex-wrap items-end justify-between gap-4">
            <div>
              <span class="eyebrow text-[11px] text-muted">Prix unitaire HT</span>
              <div class="display text-3xl font-normal text-marine"><span id="pUnit">—</span> €</div>
              <p class="mt-1 text-xs text-muted">Total (<span id="pQty">6</span> u.) : <span id="pTotal" class="font-medium text-marine">—</span> € HT</p>
            </div>
          </div>
          <div class="mt-4 flex flex-col gap-3 border-t border-soft pt-4 sm:flex-row">
            <button id="addBtn" type="button"
              class="inline-flex flex-1 items-center justify-center gap-2 rounded-xl px-6 py-2.5 text-sm font-normal text-blanc shadow-[0_10px_24px_-10px_rgba(8,151,165,0.55)] transition-transform hover:-translate-y-0.5"
              style="background-image: linear-gradient(135deg, var(--color-bleu), var(--color-turquoise));">
              Ajouter au panier
            </button>
            <button id="addDevisBtn" type="button"
              class="inline-flex flex-1 items-center justify-center gap-2 rounded-xl border border-soft bg-blanc px-6 py-2.5 text-sm font-normal text-marine transition-colors hover:border-turquoise">
              Ajouter à ma demande de devis
            </button>
          </div>
        </div>
        <p id="priceMsg" class="mt-3 text-xs text-muted"></p>
      </div>

      <!-- Panneau latéral : panier d'achat + demande de devis -->
      <div class="flex flex-col gap-6 lg:sticky lg:top-24 self-start">

        <!-- Panier d'achat -->
        <aside class="rounded-2xl border border-soft bg-white p-7 shadow-soft">
          <div class="flex items-center justify-between">
            <h3 class="display text-xl font-normal text-marine">Panier d'achat</h3>
            <span id="cartCount" class="rounded-full bg-bleu/10 px-2.5 py-0.5 text-xs font-medium text-bleu">0</span>
          </div>
          <div id="cartEmpty" class="mt-6 rounded-xl border border-dashed border-soft bg-mist px-4 py-6 text-center text-sm text-muted">
            Panier vide.<br />Configurez un filtre puis « Ajouter au panier ».
          </div>
          <ul id="cartList" class="mt-5 hidden divide-y divide-soft"></ul>
          <div id="cartFooter" class="mt-5 hidden">
            <div class="flex items-center justify-between border-t border-soft pt-4">
              <span class="text-sm text-muted">Total HT</span>
              <span class="display text-2xl font-normal text-marine"><span id="grandTotal">0</span> €</span>
            </div>
            <p class="mt-1 text-right text-xs text-muted">TVA et frais de port calculés à l'étape suivante.</p>
            <button type="button"
              class="mt-4 w-full rounded-xl px-6 py-2.5 text-sm font-normal text-blanc shadow-[0_10px_24px_-10px_rgba(8,151,165,0.55)]"
              style="background-image: linear-gradient(135deg, var(--color-bleu), var(--color-turquoise));">
              Passer commande <span class="opacity-70">(maquette)</span>
            </button>
          </div>
        </aside>

        <!-- Demande de devis (liste multi-produits) -->
        <aside class="rounded-2xl border border-soft bg-white p-7 shadow-soft">
          <div class="flex items-center justify-between">
            <h3 class="display text-xl font-normal text-marine">Ma demande de devis</h3>
            <span id="devisCount" class="rounded-full bg-turquoise/10 px-2.5 py-0.5 text-xs font-medium text-turquoise">0</span>
          </div>
          <p class="mt-1 text-xs text-muted">Plusieurs filtres possibles · prix étudié sur devis.</p>

          <div id="devisEmpty" class="mt-5 rounded-xl border border-dashed border-soft bg-mist px-4 py-6 text-center text-sm text-muted">
            Aucun filtre dans la demande.<br />Configurez un filtre puis « Ajouter à ma demande de devis ».
          </div>
          <ul id="devisList" class="mt-5 hidden divide-y divide-soft"></ul>

          <!-- Étape 1 : récapitulatif + bouton vers le formulaire -->
          <div id="devisStep1" class="mt-5 hidden">
            <button id="toFormBtn" type="button"
              class="w-full rounded-xl px-6 py-2.5 text-sm font-normal text-blanc shadow-[0_10px_24px_-10px_rgba(8,151,165,0.55)]"
              style="background-image: linear-gradient(135deg, var(--color-bleu), var(--color-turquoise));">
              Demander le devis →
            </button>
          </div>

          <!-- Étape 2 : coordonnées -->
          <form id="devisForm" class="mt-5 hidden space-y-3">
            <p class="text-sm font-medium text-marine">Vos coordonnées</p>
            <label class="block">
              <span class="eyebrow text-[11px] text-muted">Société</span>
              <input name="societe" type="text" required
                class="mt-1 w-full rounded-xl border border-soft bg-mist px-4 py-2.5 text-sm text-marine outline-none focus:border-turquoise" />
            </label>
            <label class="block">
              <span class="eyebrow text-[11px] text-muted">Nom</span>
              <input name="nom" type="text" required
                class="mt-1 w-full rounded-xl border border-soft bg-mist px-4 py-2.5 text-sm text-marine outline-none focus:border-turquoise" />
            </label>
            <label class="block">
              <span class="eyebrow text-[11px] text-muted">Email</span>
              <input name="email" type="email" required
                class="mt-1 w-full rounded-xl border border-soft bg-mist px-4 py-2.5 text-sm text-marine outline-none focus:border-turquoise" />
            </label>
            <label class="block">
              <span class="eyebrow text-[11px] text-muted">Téléphone</span>
              <input name="tel" type="tel"
                class="mt-1 w-full rounded-xl border border-soft bg-mist px-4 py-2.5 text-sm text-marine outline-none focus:border-turquoise" />
            </label>
            <label class="block">
              <span class="eyebrow text-[11px] text-muted">Message (optionnel)</span>
              <textarea name="message" rows="2"
                class="mt-1 w-full rounded-xl border border-soft bg-mist px-4 py-2.5 text-sm text-marine outline-none focus:border-turquoise"></textarea>
            </label>
            <button type="submit"
              class="w-full rounded-xl px-6 py-2.5 text-sm font-normal text-blanc shadow-[0_10px_24px_-10px_rgba(8,151,165,0.55)]"
              style="background-image: linear-gradient(135deg, var(--color-bleu), var(--color-turquoise));">
              Envoyer ma demande de devis
            </button>
            <p class="text-xs text-muted">Maquette : l'envoi réel (email / DEVIS AUTO) sera branché ensuite.</p>
          </form>

          <!-- Étape 3 : confirmation -->
          <div id="devisDone" class="mt-5 hidden rounded-xl border border-turquoise/30 bg-turquoise/5 px-4 py-5 text-sm text-marine">
            <p class="font-medium">Demande enregistrée ✓</p>
            <p id="devisDoneMsg" class="mt-1 text-xs text-muted"></p>
            <div id="devisDoneRecap" class="mt-3 space-y-1 text-xs"></div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- Appel final -->
  <section class="mx-auto max-w-[1140px] px-7 py-8">
    <div class="rounded-3xl border border-soft bg-mist px-8 py-12 text-center">
      <h2 class="display text-2xl font-normal text-marine">Un projet plus large autour de {d.nom} ?</h2>
      <p class="mx-auto mt-2 max-w-xl text-muted">
        Pour les gros volumes, appels d'offres ou conditions négociées, constituez votre demande de devis ci-dessus.
      </p>
      <a
        href="#boutique"
        class="mt-6 inline-flex items-center gap-2 rounded-xl px-6 py-2.5 text-sm font-normal text-blanc shadow-[0_10px_24px_-10px_rgba(8,151,165,0.55)] transition-transform hover:-translate-y-0.5"
        style="background-image: linear-gradient(135deg, var(--color-bleu), var(--color-turquoise));"
      >
        Configurer ma demande de devis →
      </a>
    </div>
  </section>

  <script>
    // Bloc B2 : le configurateur appelle le VRAI moteur de prix (calculerPrix).
    // Ce <script> est groupé/empaqueté par Astro (pas `is:inline`) afin de pouvoir
    // importer le moteur — qui embarque les tables tarifaires pour un calcul instantané.
    import { calculerPrix } from '../../lib/pricing';

    (function () {
      const root = document.getElementById('boutique');
      if (!root) return;
      const nom = root.dataset.nom || 'Filtre';
      const code = root.dataset.code || 'NET';
      const codeGamme = root.dataset.codegamme || '';
      const mode = root.dataset.mode || 'devis';   // "calcul" = prix instantané · "devis" = sur devis
      const $ = (id) => document.getElementById(id);
      const eur = (n) => n.toLocaleString('fr-FR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });

      // Message lisible pour un statut non vendable renvoyé par le moteur.
      function messageStatut(r) {
        if (r.message) return r.message;
        switch (r.statut) {
          case 'sur_devis': return 'Produit proposé sur devis — ajoutez-le à votre demande.';
          case 'classe_indisponible': return "Cette efficacité n'est pas disponible dans ce format.";
          case 'hors_fabrication': return 'Dimensions hors des limites de fabrication.';
          case 'quantite_insuffisante': return r.quantiteMini ? ('Quantité minimale : ' + r.quantiteMini + '.') : 'Quantité insuffisante.';
          case 'gamme_inconnue': return 'Produit non disponible à la commande en ligne.';
          default: return '';
        }
      }

      // Affiche (ou efface) le prix et pilote l'état du bouton « Ajouter au panier ».
      function afficherPrix(unit, total, msg) {
        const ok = unit != null;
        $('pUnit').textContent = ok ? eur(unit) : '—';
        $('pTotal').textContent = ok ? eur(total) : '—';
        $('priceMsg').textContent = msg || '';
        const btn = $('addBtn');
        btn.disabled = !ok;
        btn.classList.toggle('opacity-40', !ok);
        btn.classList.toggle('cursor-not-allowed', !ok);
      }

      const cart = [];   // achat (avec prix)
      const devis = [];  // demande de devis (sans prix)

      function readCfg() {
        const L = Math.max(100, +$('inL').value || 0);
        const H = Math.max(100, +$('inH').value || 0);
        const ep = +$('inEp').value || 48;
        const eff = $('inEff').value;
        const effLabel = $('inEff').selectedOptions[0].text;
        const cadreVal = $('inCadre').value;
        const cadre = cadreVal === 'pp' ? 'P' : 'A';
        const cadreLabel = cadreVal === 'pp' ? 'Polypropylène' : 'Acier galvanisé';
        const qty = Math.max(1, +$('inQ').value || 1);
        return { L, H, ep, eff, effLabel, cadre, cadreLabel, qty };
      }

      function refRef(c) {
        return `${code}-${c.eff}-${c.L}x${c.H}x${c.ep}-${c.cadre}`;
      }

      // Calcule et affiche le prix réel via le moteur. Renvoie { c, unit, ok }.
      function refresh() {
        const c = readCfg();
        $('pQty').textContent = c.qty;
        $('genRef').textContent = refRef(c);

        // Produit « sur devis » : aucun prix public, on oriente vers la demande de devis.
        if (mode !== 'calcul') {
          afficherPrix(null, null, 'Ce produit est proposé sur devis. Ajoutez-le à votre demande de devis.');
          return { c, unit: null, ok: false };
        }

        const r = calculerPrix({
          codeGamme,
          largeur_mm: c.L,
          hauteur_mm: c.H,
          profondeur_mm: c.ep,
          classe: c.eff,
          quantite: c.qty,
        });

        if (r.statut === 'ok') {
          const total = r.prixUnitaireHT * c.qty;
          afficherPrix(
            r.prixUnitaireHT, total,
            'Prix unitaire HT valable ' + r.dureeValiditeJours + " jours · TVA et frais de port à l'étape suivante.",
          );
          return { c, unit: r.prixUnitaireHT, ok: true };
        }

        // Statut non vendable (sur devis, hors format, classe indisponible…) : pas de prix inventé.
        afficherPrix(null, null, messageStatut(r));
        return { c, unit: null, ok: false };
      }

      // ---- Panier d'achat ----
      function renderCart() {
        const count = cart.reduce((s, i) => s + i.qty, 0);
        $('cartCount').textContent = count;
        const empty = cart.length === 0;
        $('cartEmpty').classList.toggle('hidden', !empty);
        $('cartList').classList.toggle('hidden', empty);
        $('cartFooter').classList.toggle('hidden', empty);
        const list = $('cartList');
        list.innerHTML = '';
        let grand = 0;
        cart.forEach((it, idx) => {
          grand += it.unit * it.qty;
          const li = document.createElement('li');
          li.className = 'flex items-start justify-between gap-3 py-3';
          li.innerHTML =
            '<div class="min-w-0">' +
              '<p class="font-mono text-xs text-marine">' + it.ref + '</p>' +
              '<p class="text-xs text-muted">' + it.qty + ' u. × ' + eur(it.unit) + ' €</p>' +
            '</div>' +
            '<div class="flex items-center gap-3 shrink-0">' +
              '<span class="text-sm font-medium text-marine">' + eur(it.unit * it.qty) + ' €</span>' +
              '<button data-rm="' + idx + '" class="text-muted hover:text-bleu" aria-label="Retirer">✕</button>' +
            '</div>';
          list.appendChild(li);
        });
        $('grandTotal').textContent = eur(grand);
        list.querySelectorAll('[data-rm]').forEach((b) =>
          b.addEventListener('click', () => { cart.splice(+b.dataset.rm, 1); renderCart(); })
        );
      }

      // ---- Demande de devis (liste multi-produits, sans prix) ----
      function renderDevis() {
        const count = devis.reduce((s, i) => s + i.qty, 0);
        $('devisCount').textContent = count;
        const empty = devis.length === 0;
        $('devisEmpty').classList.toggle('hidden', !empty);
        $('devisList').classList.toggle('hidden', empty);
        $('devisStep1').classList.toggle('hidden', empty);
        if (empty) {
          $('devisForm').classList.add('hidden');
          $('devisDone').classList.add('hidden');
        }
        const list = $('devisList');
        list.innerHTML = '';
        devis.forEach((it, idx) => {
          const li = document.createElement('li');
          li.className = 'flex items-start justify-between gap-3 py-3';
          li.innerHTML =
            '<div class="min-w-0">' +
              '<p class="font-mono text-xs text-marine">' + it.ref + '</p>' +
              '<p class="text-xs text-muted">' + it.qty + ' u. · ' + it.effLabel + ' · ' + it.cadreLabel + ' · prix sur devis</p>' +
            '</div>' +
            '<button data-rmd="' + idx + '" class="shrink-0 text-muted hover:text-turquoise" aria-label="Retirer">✕</button>';
          list.appendChild(li);
        });
        list.querySelectorAll('[data-rmd]').forEach((b) =>
          b.addEventListener('click', () => { devis.splice(+b.dataset.rmd, 1); renderDevis(); })
        );
      }

      ['inL', 'inH', 'inEp', 'inEff', 'inCadre', 'inQ'].forEach((id) =>
        $(id).addEventListener('input', refresh)
      );

      $('addBtn').addEventListener('click', () => {
        const { c, unit, ok } = refresh();
        if (!ok || unit == null) return;   // pas d'ajout sans prix (sur devis, hors format, classe indispo…)
        cart.push({ ref: refRef(c), qty: c.qty, unit });
        renderCart();
      });

      $('addDevisBtn').addEventListener('click', () => {
        const { c } = refresh();
        devis.push({
          ref: refRef(c), produit: nom, L: c.L, H: c.H, ep: c.ep,
          eff: c.eff, effLabel: c.effLabel, cadreLabel: c.cadreLabel, qty: c.qty,
        });
        // Si on revenait du formulaire/confirmation, on repart à l'étape liste.
        $('devisForm').classList.add('hidden');
        $('devisDone').classList.add('hidden');
        $('devisStep1').classList.remove('hidden');
        renderDevis();
      });

      // Étape liste → formulaire
      $('toFormBtn').addEventListener('click', () => {
        $('devisStep1').classList.add('hidden');
        $('devisForm').classList.remove('hidden');
      });

      // Envoi (maquette) → confirmation
      $('devisForm').addEventListener('submit', (e) => {
        e.preventDefault();
        const data = new FormData(e.target);
        const societe = data.get('societe') || '';
        const lignes = devis.length;
        const total = devis.reduce((s, i) => s + i.qty, 0);
        $('devisForm').classList.add('hidden');
        $('devisDoneMsg').textContent =
          `Merci ${societe}. Votre demande (${lignes} filtre${lignes > 1 ? 's' : ''}, ${total} unité${total > 1 ? 's' : ''}) a bien été prise en compte. Netair revient vers vous avec un devis chiffré.`;
        const recap = $('devisDoneRecap');
        recap.innerHTML = devis.map((it) =>
          '<p class="font-mono text-marine">' + it.ref + ' — ' + it.qty + ' u.</p>'
        ).join('');
        devis.length = 0;
        renderDevis();
        // renderDevis() réaffiche le bloc « vide » : on le masque tant que la confirmation est à l'écran.
        $('devisEmpty').classList.add('hidden');
        $('devisDone').classList.remove('hidden');
      });

      refresh();
      renderCart();
      renderDevis();
    })();
  </script>
</BaseLayout>
