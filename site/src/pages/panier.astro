---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { DEPARTEMENTS } from '../lib/departements';
---

<BaseLayout title="Panier — Netair" description="Votre panier de filtres Netair.">
  <!-- Bandeau maquette -->
  <div class="bg-marine text-blanc">
    <div class="mx-auto max-w-[1140px] px-7 py-2 text-center text-xs">
      Aperçu boutique · panier de démonstration · le <strong>paiement sera activé après immatriculation</strong>
    </div>
  </div>

  <section class="mx-auto max-w-[1140px] px-7 pt-10">
    <Breadcrumb items={[{ href: '/', label: 'Accueil' }, { label: 'Panier' }]} />
  </section>

  <section class="mx-auto max-w-[1140px] px-7 py-6">
    <h1 class="display text-4xl sm:text-5xl font-normal text-marine">Votre panier</h1>

    <!-- Panier vide -->
    <div id="vide" class="mt-8 hidden rounded-2xl border border-dashed border-soft bg-mist px-6 py-12 text-center">
      <p class="text-muted">Votre panier est vide.</p>
      <a href="/gammes" class="mt-4 inline-flex items-center gap-2 rounded-xl px-6 py-2.5 text-sm font-normal text-blanc shadow-[0_10px_24px_-10px_rgba(8,151,165,0.55)]"
        style="background-image: linear-gradient(135deg, var(--color-bleu), var(--color-turquoise));">
        Découvrir le catalogue →
      </a>
    </div>

    <!-- Panier rempli -->
    <div id="plein" class="mt-8 hidden grid gap-8 lg:grid-cols-[1.5fr_1fr] items-start">
      <!-- Lignes -->
      <div>
        <ul id="lignes" class="divide-y divide-soft rounded-2xl border border-soft bg-white"></ul>
        <a href="/gammes" class="mt-4 inline-flex items-center gap-1.5 text-sm font-normal text-muted transition-colors hover:text-bleu">
          ← Continuer mes achats
        </a>
      </div>

      <!-- Récapitulatif + commande -->
      <aside class="rounded-2xl border border-soft bg-white p-7 shadow-soft lg:sticky lg:top-24">
        <h2 class="display text-xl font-normal text-marine">Récapitulatif</h2>

        <!-- Département de livraison → estime le port immédiatement -->
        <label class="mt-5 block">
          <span class="eyebrow text-[11px] text-muted">Département de livraison</span>
          <select id="dept"
            class="mt-1 w-full rounded-xl border border-soft bg-mist px-4 py-2.5 text-sm text-marine outline-none focus:border-turquoise">
            <option value="">— Choisir un département —</option>
            {DEPARTEMENTS.map((d) => <option value={d.code}>{d.code} — {d.nom}</option>)}
          </select>
        </label>
        <p class="mt-1.5 text-[11px] text-muted">Livraison en France métropolitaine et Corse.</p>

        <!-- Détail du total -->
        <div class="mt-5 space-y-2 border-t border-soft pt-4">
          <div class="flex items-center justify-between">
            <span class="text-sm text-muted">Sous-total produits HT</span>
            <span class="text-sm text-marine"><span id="sousTotal">0</span> €</span>
          </div>
          <div class="flex items-center justify-between">
            <span class="text-sm text-muted">Frais de port HT</span>
            <span id="port" class="text-sm text-marine">à préciser</span>
          </div>
        </div>
        <div class="mt-3 flex items-center justify-between border-t border-soft pt-3">
          <span class="text-sm font-medium text-marine">Total HT</span>
          <span class="display text-2xl font-normal text-marine"><span id="total">0</span> €</span>
        </div>
        <p id="franco" class="mt-2 text-right text-xs text-muted"></p>
        <p class="mt-1 text-right text-xs text-muted">TVA calculée à la commande.</p>

        <!-- Minimum de facturation : message affiché quand le sous-total produits est sous le plancher -->
        <p id="minMsg" class="mt-4 hidden rounded-xl border border-soft bg-mist px-4 py-2.5 text-xs text-marine"></p>

        <!-- Étape 1 : bouton commander -->
        <button id="toForm" type="button"
          class="mt-5 w-full rounded-xl px-6 py-2.5 text-sm font-normal text-blanc shadow-[0_10px_24px_-10px_rgba(8,151,165,0.55)] disabled:cursor-not-allowed disabled:opacity-50"
          style="background-image: linear-gradient(135deg, var(--color-bleu), var(--color-turquoise));">
          Passer commande →
        </button>

        <!-- Étape 2 : coordonnées -->
        <form id="form" class="mt-5 hidden space-y-3">
          <p class="text-sm font-medium text-marine">Vos coordonnées de livraison</p>
          <label class="block">
            <span class="eyebrow text-[11px] text-muted">Société</span>
            <input name="societe" type="text" required class="mt-1 w-full rounded-xl border border-soft bg-mist px-4 py-2.5 text-sm text-marine outline-none focus:border-turquoise" />
          </label>
          <label class="block">
            <span class="eyebrow text-[11px] text-muted">Nom</span>
            <input name="nom" type="text" required class="mt-1 w-full rounded-xl border border-soft bg-mist px-4 py-2.5 text-sm text-marine outline-none focus:border-turquoise" />
          </label>
          <label class="block">
            <span class="eyebrow text-[11px] text-muted">Email</span>
            <input name="email" type="email" required class="mt-1 w-full rounded-xl border border-soft bg-mist px-4 py-2.5 text-sm text-marine outline-none focus:border-turquoise" />
          </label>
          <label class="block">
            <span class="eyebrow text-[11px] text-muted">Adresse de livraison</span>
            <textarea name="adresse" rows="2" required class="mt-1 w-full rounded-xl border border-soft bg-mist px-4 py-2.5 text-sm text-marine outline-none focus:border-turquoise"></textarea>
          </label>
          <button type="submit"
            class="w-full rounded-xl px-6 py-2.5 text-sm font-normal text-blanc shadow-[0_10px_24px_-10px_rgba(8,151,165,0.55)]"
            style="background-image: linear-gradient(135deg, var(--color-bleu), var(--color-turquoise));">
            Valider la commande
          </button>
          <p class="text-xs text-muted">Maquette : le paiement par carte sera branché après immatriculation.</p>
        </form>

        <!-- Étape 3 : confirmation -->
        <div id="done" class="mt-5 hidden rounded-xl border border-turquoise/30 bg-turquoise/5 px-4 py-5 text-sm text-marine">
          <p class="font-medium">Commande enregistrée ✓</p>
          <p id="doneMsg" class="mt-1 text-xs text-muted"></p>
        </div>
      </aside>
    </div>
  </section>

  <script>
    import { getCart, setQty, removeItem, cartTotalHT, onCartChange, getDeliveryDept, setDeliveryDept } from '../lib/cart';
    import { calculerPrix } from '../lib/pricing';
    import { calculerPort, seuilFranco } from '../lib/pricing/shipping';
    import { MIN_COMMANDE_HT } from '../lib/boutique';

    const $ = (id) => document.getElementById(id);
    const eur = (n) => n.toLocaleString('fr-FR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });

    /**
     * Un SEUL frais de port pour tout le panier : calculé sur le total produits + le
     * département (franco global à 750 €). Port inconnu (dépt absent/non tarifé) → non
     * ajouté au total, mais la commande reste possible (port réglé au devis).
     */
    function computeTotals() {
      const subtotal = cartTotalHT();
      const dept = getDeliveryDept().trim();
      let portHT = null, franco = false, surDevis = false;
      let portLabel = 'à préciser';
      if (dept) {
        const r = calculerPort(dept, subtotal);
        if (r.portSurDevis) { surDevis = true; portLabel = 'sur devis'; }
        else if (r.francoApplique) { portHT = 0; franco = true; portLabel = 'offert'; }
        else if (r.fraisPortHT != null) { portHT = r.fraisPortHT; portLabel = eur(portHT) + ' €'; }
        else { surDevis = true; portLabel = 'sur devis'; } // filet : port manquant → jamais de NaN
      }
      const total = subtotal + (portHT || 0);
      return { subtotal, dept, portHT, portLabel, franco, surDevis, total };
    }

    function renderTotals() {
      const t = computeTotals();
      $('sousTotal').textContent = eur(t.subtotal);
      $('port').textContent = t.portLabel;
      $('total').textContent = eur(t.total);
      const fr = $('franco');
      if (t.franco) {
        fr.textContent = '✓ Port offert (commande ≥ ' + eur(seuilFranco(t.dept)) + ' € HT).';
        fr.className = 'mt-2 text-right text-xs text-turquoise';
      } else if (t.dept && !t.surDevis) {
        const reste = seuilFranco(t.dept) - t.subtotal;
        fr.textContent = reste > 0 ? 'Plus que ' + eur(reste) + ' € HT pour le port offert (dès ' + eur(seuilFranco(t.dept)) + ' €).' : '';
        fr.className = 'mt-2 text-right text-xs text-muted';
      } else {
        fr.textContent = '';
      }
      appliquerMinimum();
    }

    // Bloque la commande sous le minimum de facturation (produits HT hors port).
    function appliquerMinimum() {
      const bloque = cartTotalHT() < MIN_COMMANDE_HT;
      $('toForm').disabled = bloque;
      const msg = $('minMsg');
      if (bloque) {
        const manque = MIN_COMMANDE_HT - cartTotalHT();
        msg.textContent = 'Montant minimum de commande : ' + eur(MIN_COMMANDE_HT) + ' € HT (il manque ' + eur(manque) + ' €).';
        msg.classList.remove('hidden');
        // Si le tunnel était ouvert et qu'on repasse sous le minimum, on le referme.
        if (!$('form').classList.contains('hidden')) {
          $('form').classList.add('hidden');
          $('toForm').classList.remove('hidden');
        }
      } else {
        msg.classList.add('hidden');
      }
      return bloque;
    }

    function render() {
      const items = getCart();
      const empty = items.length === 0;
      $('vide').classList.toggle('hidden', !empty);
      $('plein').classList.toggle('hidden', empty);
      if (empty) return;

      // Département mémorisé (sans écraser la saisie en cours ni bouger le curseur).
      if (document.activeElement !== $('dept')) $('dept').value = getDeliveryDept();

      const list = $('lignes');
      list.innerHTML = '';
      items.forEach((it) => {
        const li = document.createElement('li');
        li.className = 'flex items-start justify-between gap-3 p-4 sm:gap-4 sm:p-5';
        li.innerHTML =
          '<div class="min-w-0">' +
            '<p class="font-mono text-sm text-marine">' + it.ref + '</p>' +
            '<p class="mt-0.5 text-xs text-muted">' + (it.detail || '') + '</p>' +
            '<p class="mt-1 text-xs text-muted">' + eur(it.unit) + ' € HT / u.</p>' +
          '</div>' +
          '<div class="flex items-center gap-2.5 shrink-0 sm:gap-4">' +
            '<input type="number" min="1" max="100000" value="' + it.qty + '" data-qty="' + it.ref + '" ' +
              'class="w-14 rounded-xl border border-soft bg-mist px-2 py-1.5 text-center text-sm text-marine outline-none focus:border-turquoise sm:w-16" />' +
            '<span class="w-20 text-right text-sm font-medium text-marine sm:w-24">' + eur(it.unit * it.qty) + ' €</span>' +
            '<button data-rm="' + it.ref + '" class="text-muted hover:text-bleu" aria-label="Retirer">✕</button>' +
          '</div>';
        list.appendChild(li);
      });
      renderTotals();

      list.querySelectorAll('[data-qty]').forEach((inp) =>
        inp.addEventListener('change', () => {
          const ref = inp.dataset.qty;
          const qty = Math.max(1, +inp.value || 1);
          // Re-calcul du prix unitaire selon le palier de quantité (si la config est mémorisée).
          const it = getCart().find((i) => i.ref === ref);
          let unit;
          if (it && it.demande) {
            const r = calculerPrix({ ...it.demande, quantite: qty });
            if (r.statut === 'ok' && r.prixUnitaireHT != null) unit = r.prixUnitaireHT;
          }
          setQty(ref, qty, unit); // unit indéfini → garde le prix d'ajout (article ancien)
        })
      );
      list.querySelectorAll('[data-rm]').forEach((b) =>
        b.addEventListener('click', () => removeItem(b.dataset.rm))
      );
    }

    // Purge d'une valeur mémorisée absente du menu (ancien champ libre, DROM retiré) →
    // évite un menu vide affiché avec un port incohérent.
    (() => {
      const sel = $('dept');
      const memo = getDeliveryDept();
      if (memo && !Array.from(sel.options).some((o) => o.value === memo)) setDeliveryDept('');
    })();

    // Département : mémorise et recalcule le port en direct (sans reconstruire les lignes).
    $('dept').addEventListener('change', () => {
      setDeliveryDept($('dept').value.trim());
      renderTotals();
    });

    // Tunnel de commande (maquette)
    $('toForm').addEventListener('click', () => {
      $('toForm').classList.add('hidden');
      $('form').classList.remove('hidden');
      // Pré-remplir l'adresse avec le département déjà saisi (si l'adresse est vide).
      const dep = getDeliveryDept().trim();
      const adr = $('form').querySelector('[name="adresse"]');
      if (dep && adr && !adr.value.trim()) adr.value = 'Département ' + dep + ' — ';
    });

    $('form').addEventListener('submit', (e) => {
      e.preventDefault();
      if (appliquerMinimum()) return; // garde : jamais de commande sous le minimum, même si le formulaire est ré-affiché
      const societe = new FormData(e.target).get('societe') || '';
      const nb = getCart().reduce((s, i) => s + i.qty, 0);
      const t = computeTotals();
      const portTxt = t.surDevis ? 'port sur devis'
        : t.franco ? 'port offert'
        : t.portHT != null ? 'port ' + eur(t.portHT) + ' € HT'
        : 'port à préciser';
      $('form').classList.add('hidden');
      $('doneMsg').textContent =
        'Merci ' + societe + '. Votre commande (' + nb + ' article(s), ' + eur(t.total) +
        ' € HT, ' + portTxt + ') a bien été enregistrée. Le paiement sera activé après immatriculation de Netair.';
      $('done').classList.remove('hidden');
    });

    render();
    onCartChange(render);
  </script>
</BaseLayout>
