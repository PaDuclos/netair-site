---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import {
  getProduits,
  familleBySlug,
  SLUG_FAMILLE,
  type Produit,
} from '../../lib/familles';

export async function getStaticPaths() {
  const produits = await getProduits();
  return produits.map((p) => ({ params: { ref: p.id }, props: { produit: p } }));
}

interface Props {
  produit: Produit;
}
const { produit } = Astro.props;
const d = produit.data;

const famille = familleBySlug(SLUG_FAMILLE[produit.id] ?? '');
const img = d.photo ? `/produits/${d.photo}` : null;

// Lien vers la fiche technique générée (servie depuis /public/fiches-techniques/).
const ficheHref = `/fiches-techniques/${encodeURIComponent(`Fiche technique ${d.nom}.html`)}`;

const badges: string[] = d.badges_p1 ?? [];
const specs: string[][] = d.specs ?? [];
const points: string[] = d.points_cles ?? [];
---

<BaseLayout
  title={`${d.nom} — ${d.soustitre ?? 'Filtre CTA'} | Netair`}
  description={(d.description ?? `${d.nom}, filtre pour centrale de traitement d'air.`).slice(0, 300)}
  ogImage={img ?? '/brand/logo.png'}
>
  <section class="mx-auto max-w-[1140px] px-7 pt-10">
    <Breadcrumb
      items={[
        { href: '/', label: 'Accueil' },
        { href: '/gammes', label: 'Gammes' },
        ...(famille ? [{ href: `/gammes/${famille.slug}`, label: famille.titre }] : []),
        { label: d.nom },
      ]}
    />
  </section>

  <!-- En-tête produit -->
  <section class="mx-auto max-w-[1140px] px-7 py-8 grid items-start gap-10 lg:grid-cols-2">
    {img && (
      <div class="rounded-2xl border border-soft bg-mist p-6">
        <img src={img} alt={d.photo_alt ?? `Filtre ${d.nom}`} class="mx-auto h-auto w-full max-w-md object-contain" width="520" height="400" />
      </div>
    )}
    <div>
      {famille && <span class="eyebrow text-xs text-turquoise">{famille.titre}</span>}
      <h1 class="display mt-2 text-4xl sm:text-5xl font-bold text-marine">{d.nom}</h1>
      {d.soustitre && <p class="mt-2 text-lg text-muted">{d.soustitre}</p>}

      {badges.length > 0 && (
        <div class="mt-5 flex flex-wrap gap-2">
          {badges.map((b) => (
            <span class="rounded-lg bg-bleu/8 px-3 py-1.5 text-xs font-semibold text-bleu">{b}</span>
          ))}
        </div>
      )}

      {points.length > 0 && (
        <ul class="mt-6 grid gap-2 sm:grid-cols-2">
          {points.map((pt) => (
            <li class="flex items-start gap-2 text-sm text-marine">
              <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-turquoise"></span>
              {pt}
            </li>
          ))}
        </ul>
      )}

      <div class="mt-8 flex flex-wrap gap-3">
        <a
          href="/contact"
          class="inline-flex items-center gap-2 rounded-xl px-5 py-3 text-sm font-semibold text-blanc shadow-[0_10px_24px_-10px_rgba(8,151,165,0.55)] transition-transform hover:-translate-y-0.5"
          style="background-image: linear-gradient(135deg, var(--color-bleu), var(--color-turquoise));"
        >
          Demander un devis →
        </a>
        <a
          href={ficheHref}
          class="inline-flex items-center gap-2 rounded-xl border border-soft bg-blanc px-5 py-3 text-sm font-semibold text-marine transition-colors hover:border-turquoise"
        >
          Fiche technique
        </a>
      </div>
    </div>
  </section>

  <!-- Description -->
  {d.description && (
    <section class="mx-auto max-w-[1140px] px-7 py-6">
      <h2 class="eyebrow text-xs text-turquoise">Description</h2>
      <p class="mt-3 max-w-3xl text-lg leading-relaxed text-marine">{d.description}</p>
    </section>
  )}

  <!-- Caractéristiques -->
  {specs.length > 0 && (
    <section class="mx-auto max-w-[1140px] px-7 py-6">
      <h2 class="display text-2xl font-bold text-marine">Caractéristiques</h2>
      <div class="mt-5 overflow-hidden rounded-2xl border border-soft">
        <table class="w-full text-sm">
          <tbody>
            {specs.map((row, i) => (
              <tr class={i % 2 ? 'bg-mist' : 'bg-blanc'}>
                <th scope="row" class="w-1/3 px-5 py-3 text-left font-medium text-muted align-top">{row[0]}</th>
                <td class="px-5 py-3 text-marine">{row[1]}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="mt-3 text-xs text-muted">
        Valeurs issues de la fiche technique du produit. Perte de charge et classement énergétique détaillés sur la fiche.
      </p>
    </section>
  )}

  <!-- Emplacement réservé : futur calculateur / vue 3D -->
  <section class="mx-auto max-w-[1140px] px-7 py-6">
    <div class="rounded-2xl border border-dashed border-soft bg-mist/60 p-6 text-center text-sm text-muted">
      Calculateur énergétique et vue 3D : à intégrer ici (étapes suivantes).
    </div>
  </section>

  <!-- Appel final -->
  <section class="mx-auto max-w-[1140px] px-7 py-8">
    <div class="rounded-3xl border border-soft bg-mist px-8 py-12 text-center">
      <h2 class="display text-2xl font-bold text-marine">Besoin de {d.nom} pour votre installation ?</h2>
      <p class="mx-auto mt-2 max-w-xl text-muted">
        Indiquez vos dimensions, le débit et la classe visée ; nous revenons avec une proposition adaptée.
      </p>
      <a
        href="/contact"
        class="mt-6 inline-flex items-center gap-2 rounded-xl px-6 py-3 text-sm font-semibold text-blanc shadow-[0_10px_24px_-10px_rgba(8,151,165,0.55)] transition-transform hover:-translate-y-0.5"
        style="background-image: linear-gradient(135deg, var(--color-bleu), var(--color-turquoise));"
      >
        Demander un devis →
      </a>
    </div>
  </section>
</BaseLayout>
