---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import ProductCard from '../../components/ProductCard.astro';
import { FAMILLES, getProduitsByFamille, type Produit } from '../../lib/familles';

export async function getStaticPaths() {
  return Promise.all(
    FAMILLES.map(async (f) => ({
      params: { famille: f.slug },
      props: { famille: f, produits: await getProduitsByFamille(f.slug) },
    })),
  );
}

interface Props {
  famille: (typeof FAMILLES)[number];
  produits: Produit[];
}
const { famille, produits } = Astro.props;
---

<BaseLayout
  title={`${famille.titre} — Filtres CTA Netair`}
  description={famille.desc}
>
  <section class="mx-auto max-w-[1140px] px-7 pt-10 pb-4">
    <Breadcrumb
      items={[
        { href: '/', label: 'Accueil' },
        { href: '/gammes', label: 'Gammes' },
        { label: famille.titre },
      ]}
    />
    <span class="eyebrow mt-5 inline-block text-xs text-turquoise">{famille.tag}</span>
    <h1 class="display mt-2 text-4xl sm:text-5xl font-bold text-marine">{famille.titre}</h1>
    <p class="mt-4 max-w-2xl text-lg text-muted">{famille.desc}</p>
  </section>

  <section class="mx-auto max-w-[1140px] px-7 py-8">
    {produits.length > 0 ? (
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {produits.map((p) => <ProductCard produit={p} />)}
      </div>
    ) : (
      <div class="rounded-2xl border border-soft bg-mist p-10 text-center">
        <p class="text-marine font-medium">Références en cours de référencement.</p>
        <p class="mt-2 text-sm text-muted">
          Cette famille fait partie de notre gamme. Pour une demande précise,
          contactez-nous : nous étudions chaque cas.
        </p>
        <a
          href="/contact"
          class="mt-6 inline-flex items-center gap-2 rounded-xl px-5 py-3 text-sm font-semibold text-blanc"
          style="background-image: linear-gradient(135deg, var(--color-bleu), var(--color-turquoise));"
        >
          Demander un devis →
        </a>
      </div>
    )}
  </section>
</BaseLayout>
